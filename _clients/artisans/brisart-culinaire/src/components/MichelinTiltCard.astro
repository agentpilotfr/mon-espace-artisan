---
// Tilt card Bib Gourmand — bib.png centré, effet 3D au hover
---

<div class="tilt-card" id="michelin-tilt-card" aria-label="Guide Michelin Bib Gourmand 2026">
  <div class="tilt-inner">
    <div class="tilt-shine" aria-hidden="true"></div>

    <!-- Bib Gourmand photo -->
    <div class="tilt-bib" aria-hidden="true">
      <img
        src="/images/guillaume/distinctions/bib.png"
        alt="Bibendum Bib Gourmand Michelin"
        width="160"
        height="160"
        loading="lazy"
        class="bib-img"
      />
    </div>

    <!-- Texte -->
    <div class="tilt-content">
      <span class="tilt-label">Michelin Bib Gourmand</span>
      <span class="tilt-year">2026</span>
    </div>
  </div>
</div>

<script>
  const card = document.getElementById('michelin-tilt-card');
  if (card) {
    const inner = card.querySelector<HTMLElement>('.tilt-inner');
    const shine = card.querySelector<HTMLElement>('.tilt-shine');
    const MAX = 15;

    card.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = card.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width;
      const y = (e.clientY - rect.top) / rect.height;
      const rotX = (y - 0.5) * -MAX * 2;
      const rotY = (x - 0.5) * MAX * 2;
      if (inner) {
        inner.style.transition = 'transform 0.05s linear';
        inner.style.transform = `perspective(1000px) rotateX(${rotX}deg) rotateY(${rotY}deg) scale(1.04)`;
      }
      if (shine) {
        shine.style.background = `radial-gradient(circle at ${(x*100).toFixed(0)}% ${(y*100).toFixed(0)}%, rgba(255,255,255,0.12) 0%, transparent 65%)`;
      }
    });

    card.addEventListener('mouseleave', () => {
      if (inner) {
        inner.style.transition = 'transform 0.5s ease';
        inner.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg) scale(1)';
      }
      if (shine) shine.style.background = 'none';
    });
  }
</script>

<style>
  .tilt-card {
    width: 260px;
    height: 320px;
    border-radius: 12px;
    cursor: pointer;
    flex-shrink: 0;
    perspective: 1000px;
  }

  .tilt-inner {
    width: 100%;
    height: 100%;
    border-radius: 12px;
    background: #CC0000;
    box-shadow: 0 24px 64px rgba(204,0,0,0.3);
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    padding: 2rem 1.5rem 1.75rem;
  }

  /* Subtle grain texture */
  .tilt-inner::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 30% 15%, rgba(255,255,255,0.1) 0%, transparent 55%),
      radial-gradient(ellipse at 75% 80%, rgba(0,0,0,0.12) 0%, transparent 50%);
    pointer-events: none;
  }

  .tilt-shine {
    position: absolute;
    inset: 0;
    border-radius: 12px;
    pointer-events: none;
    z-index: 3;
    transition: background 0.08s ease;
  }

  .tilt-bib {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 2;
  }

  .bib-img {
    width: 160px;
    height: auto;
    filter: brightness(0) invert(1);
    display: block;
    user-select: none;
    pointer-events: none;
    drop-shadow: 0 4px 12px rgba(0,0,0,0.3);
  }

  .tilt-content {
    position: relative;
    z-index: 2;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }

  .tilt-label {
    font-family: "DM Mono", monospace;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.8);
    display: block;
  }

  .tilt-year {
    font-family: "Cormorant Garamond", Georgia, serif;
    font-style: italic;
    font-size: 2.8rem;
    color: white;
    line-height: 1;
    display: block;
  }
</style>

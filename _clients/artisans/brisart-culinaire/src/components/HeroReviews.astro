---
interface ReviewBadge {
  platform: 'google' | 'tripadvisor' | 'michelin' | 'custom';
  score: string;
  count: string;
  url?: string;
  label: string;
}

interface Props {
  badges: ReviewBadge[];
}

const { badges } = Astro.props;

const nonMichelinBadges = badges.filter(b => b.platform !== 'michelin');
const michelinBadge = badges.find(b => b.platform === 'michelin');
const MICHELIN_ARTICLE_URL = "https://actu.fr/pays-de-la-loire/la-baule-escoublac_44055/ce-restaurant-de-loire-atlantique-recompense-par-le-guide-michelin-six-mois-seulement-apres-son-ouverture_63844228.html";

const svgs: Record<string, string> = {
  google: `<svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true" style="flex-shrink:0;">
    <path d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844a4.14 4.14 0 0 1-1.796 2.716v2.259h2.908C16.658 14.103 17.64 11.851 17.64 9.2Z" fill="#4285F4"/>
    <path d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18Z" fill="#34A853"/>
    <path d="M3.964 10.71A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.042l3.007-2.332Z" fill="#FBBC05"/>
    <path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.958L3.964 7.29C4.672 5.163 6.656 3.58 9 3.58Z" fill="#EA4335"/>
  </svg>`,
  tripadvisor: `<svg width="20" height="14" viewBox="0 0 20 14" fill="none" aria-hidden="true" style="flex-shrink:0;">
    <circle cx="5" cy="7" r="4.5" fill="#00AA6C" opacity="0.9"/>
    <circle cx="15" cy="7" r="4.5" fill="#00AA6C" opacity="0.9"/>
    <circle cx="5" cy="7" r="2" fill="white"/>
    <circle cx="15" cy="7" r="2" fill="white"/>
    <circle cx="5" cy="7" r="0.9" fill="#00AA6C"/>
    <circle cx="15" cy="7" r="0.9" fill="#00AA6C"/>
    <path d="M10 2.5 L7.5 5 L10 3.5 L12.5 5 Z" fill="#00AA6C"/>
  </svg>`,
};
---

<div class="hero-reviews" role="list" aria-label="Avis et distinctions">

  <!-- Google + TripAdvisor côte à côte -->
  <div class="hero-badges-top">
    {nonMichelinBadges.map((badge, i) => (
      <>
        {i > 0 && <div class="review-divider" aria-hidden="true"></div>}
        <a
          href={badge.url}
          target="_blank"
          rel="noopener"
          class:list={['review-badge', i === 0 && 'review-badge--primary']}
          role="listitem"
          aria-label={`${badge.score ? badge.score + ' sur 5 — ' : ''}${badge.count} ${badge.label}`}
        >
          {svgs[badge.platform]
            ? <Fragment set:html={svgs[badge.platform]} />
            : <span class="review-custom-icon" aria-hidden="true">★</span>
          }
          <div class="review-content">
            {badge.score && (
              <div class="review-stars-row">
                <span class="review-stars" aria-hidden="true">★★★★★</span>
                <span class="review-score">{badge.score}</span>
              </div>
            )}
            <div class="review-meta">
              <span class="review-count">{badge.count}</span>
              <span class="review-platform">{badge.label}</span>
            </div>
          </div>
        </a>
      </>
    ))}
  </div>

  <!-- Bib Gourmand — lien article, seul en dessous sur mobile -->
  {michelinBadge && (
    <>
      <div class="review-divider hero-bib-divider" aria-hidden="true"></div>
      <a
        href={MICHELIN_ARTICLE_URL}
        target="_blank"
        rel="noopener"
        aria-label="Lire l'article — Bib Gourmand Michelin 2026"
        class="hero-bib-link"
        role="listitem"
      >
        <div
          class="hero-bib-tilt"
          id="hero-bib-tilt"
          aria-label="Bib Gourmand Michelin 2026"
        >
          <div class="hero-bib-tilt__shine" aria-hidden="true"></div>
          <div class="hero-bib-tilt__inner">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              class="hero-bib-tilt__svg"
              fill="none"
              stroke="#ffffff"
              stroke-width="1"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-label="Bib Gourmand Michelin"
            >
              <path d="M4.97 20c-2.395 -1.947 -4.763 -5.245 -1.005 -8c-.52 -4 3.442 -7.5 5.524 -7.5c.347 -1 1.499 -1.5 2.54 -1.5c1.04 0 2.135 .5 2.482 1.5c2.082 0 6.044 3.5 5.524 7.5c3.758 2.755 1.39 6.053 -1.005 8" />
              <path d="M9 11m-1 0a1 2 0 1 0 2 0a1 2 0 1 0 -2 0" />
              <path d="M15 11m-1 0a1 2 0 1 0 2 0a1 2 0 1 0 -2 0" />
              <path d="M8 17.085c3.5 2.712 6.5 2.712 9 -1.085" />
              <path d="M13 18.5c.815 -2.337 1.881 -1.472 2 -.55" />
            </svg>
            <div class="hero-bib-tilt__label">
              <span class="hero-bib-tilt__name">Bib Gourmand</span>
              <span class="hero-bib-tilt__year">2026</span>
            </div>
          </div>
        </div>
      </a>
    </>
  )}
</div>

<style>
  .hero-reviews {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    flex-wrap: nowrap;
    gap: 0.75rem;
    margin: 1.75rem 0 2.25rem;
  }

  .hero-badges-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .hero-bib-link {
    display: inline-block;
    text-decoration: none;
    flex-shrink: 0;
  }

  .review-badge {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    background: rgba(15, 14, 11, 0.55);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(201, 164, 74, 0.2);
    border-radius: 50px;
    padding: 0.5rem 1.1rem 0.5rem 0.75rem;
    text-decoration: none;
    transition: border-color 0.25s, background 0.25s;
    cursor: pointer;
    pointer-events: all;
  }
  a.review-badge:hover {
    border-color: rgba(201, 164, 74, 0.55);
    background: rgba(15, 14, 11, 0.75);
  }
  .review-badge--primary {
    border-color: rgba(201, 164, 74, 0.35);
  }

  .review-content {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .review-stars-row {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }
  .review-stars {
    color: var(--gold-base);
    font-size: 0.7rem;
    letter-spacing: 1.5px;
    line-height: 1;
  }
  .review-score {
    color: var(--parchment);
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 700;
    line-height: 1;
  }
  .review-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .review-count {
    color: var(--parchment);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    opacity: 0.9;
  }
  .review-platform {
    color: var(--stone-light);
    font-family: var(--font-mono);
    font-size: 0.58rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    opacity: 0.7;
  }
  .review-custom-icon {
    color: var(--gold-base);
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  .review-divider {
    width: 1px;
    height: 2.5rem;
    background: rgba(201, 164, 74, 0.15);
    flex-shrink: 0;
  }

  /* ─── Bib Gourmand — grande carte rouge + parallax tilt ─── */
  .hero-bib-tilt {
    position: relative;
    width: 90px;
    height: 110px;
    border-radius: 14px;
    background: linear-gradient(145deg, #b91c1c 0%, #dc2626 50%, #991b1b 100%);
    border: 1px solid rgba(255, 255, 255, 0.15);
    overflow: hidden;
    transform-style: preserve-3d;
    transform: perspective(400px) rotateX(0deg) rotateY(0deg);
    cursor: pointer;
    flex-shrink: 0;
    animation: bibFloat 4s ease-in-out infinite;
  }

  .hero-bib-tilt:hover,
  .hero-bib-link:hover .hero-bib-tilt {
    animation-play-state: paused;
  }

  .hero-bib-tilt__shine {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(
      135deg,
      transparent 30%,
      rgba(255, 255, 255, 0.20) 50%,
      transparent 70%
    );
    background-size: 200% 200%;
    animation: bibShimmer 3.5s ease-in-out infinite;
    pointer-events: none;
    z-index: 1;
  }

  .hero-bib-tilt__inner {
    position: relative;
    z-index: 2;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 8px 6px;
  }

  .hero-bib-tilt__svg {
    width: 48px;
    height: 48px;
    flex-shrink: 0;
    transform: translateZ(8px);
    transition: transform 0.1s ease;
    filter: drop-shadow(0 1px 4px rgba(0, 0, 0, 0.35));
  }

  .hero-bib-tilt__label {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1px;
  }

  .hero-bib-tilt__name {
    font-family: 'Jost', sans-serif;
    font-size: 8px;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
    line-height: 1.2;
  }

  .hero-bib-tilt__year {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.85);
    letter-spacing: 0.06em;
    line-height: 1.2;
  }

  @keyframes bibFloat {
    0%, 100% {
      box-shadow: 0 4px 20px rgba(185, 28, 28, 0.45),
                  0 0 0 1px rgba(255, 255, 255, 0.08);
      transform: perspective(400px) rotateX(0deg) rotateY(0deg) translateY(0px);
    }
    50% {
      box-shadow: 0 8px 32px rgba(185, 28, 28, 0.65),
                  0 0 0 1px rgba(255, 255, 255, 0.14);
      transform: perspective(400px) rotateX(2deg) rotateY(-2deg) translateY(-3px);
    }
  }

  @keyframes bibShimmer {
    0%   { background-position: -200% -200%; opacity: 0.6; }
    50%  { background-position: 200% 200%;  opacity: 1; }
    100% { background-position: -200% -200%; opacity: 0.6; }
  }

  @media (max-width: 768px) {
    .hero-bib-tilt        { width: 72px; height: 88px; }
    .hero-bib-tilt__svg   { width: 38px; height: 38px; }
    .hero-bib-tilt__name  { font-size: 7px; }
    .hero-bib-tilt__year  { font-size: 9px; }
  }

  @media (max-width: 480px) {
    .hero-reviews {
      flex-direction: column;
      align-items: center;
      gap: 8px;
    }
    .hero-badges-top {
      display: flex;
      gap: 5px;
      max-width: calc(100vw - 24px);
    }
    .hero-bib-divider {
      display: none;
    }
    /* Bib seule sur sa ligne — taille pleine */
    .hero-bib-tilt        { width: 90px; height: 110px; border-radius: 14px; }
    .hero-bib-tilt__svg   { width: 44px; height: 44px; }
    .hero-bib-tilt__name  { font-size: 8px; letter-spacing: 0.08em; }
    .hero-bib-tilt__year  { font-size: 11px; }

    .review-badge {
      padding: 5px 9px 5px 6px;
      gap: 4px;
      flex-shrink: 1;
      min-width: 0;
    }
    .review-score {
      font-size: 11px;
      line-height: 1;
      white-space: nowrap;
    }
    .review-stars {
      font-size: 7px;
      letter-spacing: -1px;
      white-space: nowrap;
      overflow: hidden;
    }
    .review-count {
      display: none;
    }
    .review-platform {
      font-size: 7px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: 52px;
    }
    .review-divider {
      display: none;
    }
  }
</style>

<script>
  (function () {
    const bibCard = document.getElementById('hero-bib-tilt');
    if (!bibCard) return;

    bibCard.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = bibCard.getBoundingClientRect();
      const cx = rect.left + rect.width / 2;
      const cy = rect.top + rect.height / 2;
      const dx = (e.clientX - cx) / (rect.width / 2);
      const dy = (e.clientY - cy) / (rect.height / 2);
      const rotX = -dy * 18;
      const rotY =  dx * 18;
      (bibCard as HTMLElement).style.transition = 'transform 0.05s linear, box-shadow 0.05s linear';
      (bibCard as HTMLElement).style.transform =
        `perspective(400px) rotateX(${rotX}deg) rotateY(${rotY}deg)`;
      const svgEl = bibCard.querySelector<HTMLElement>('.hero-bib-tilt__svg');
      if (svgEl) {
        svgEl.style.transition = 'transform 0.05s linear';
        svgEl.style.transform =
          `translateZ(14px) translateX(${(dx * 5).toFixed(1)}px) translateY(${(dy * 5).toFixed(1)}px)`;
      }
    });

    bibCard.addEventListener('mouseleave', () => {
      (bibCard as HTMLElement).style.transition = 'transform 0.5s ease, box-shadow 0.5s ease';
      (bibCard as HTMLElement).style.transform =
        'perspective(400px) rotateX(0deg) rotateY(0deg)';
      const svgEl = bibCard.querySelector<HTMLElement>('.hero-bib-tilt__svg');
      if (svgEl) {
        svgEl.style.transition = 'transform 0.5s ease';
        svgEl.style.transform = 'translateZ(8px)';
      }
    });
  })();
</script>

---
const temoignages = [
  {
    texte: "Chaque plat est une histoire. La table du Chef de Guillaume m'a réconciliée avec la vraie cuisine. Un moment hors du temps, une adresse que je recommande à tous les amoureux de gastronomie authentique.",
    nom:   'Isabelle M.',
    lieu:  'La Baule',
    note:  5,
    date:  'Novembre 2025',
  },
  {
    texte: "J'ai suivi trois ateliers en groupe. Aujourd'hui je cuisine pour ma famille avec une technique et une confiance que je n'aurais jamais cru avoir. Guillaume a cette rare capacité de transmettre sans jamais intimider.",
    nom:   'Thomas R.',
    lieu:  'Périgueux',
    note:  5,
    date:  'Janvier 2026',
  },
  {
    texte: "La Table du Chef d'automne était une symphonie. Les accords avec les vins naturels et locaux, l'attention portée à chaque détail, la qualité des produits... Déjà réservé pour la prochaine saison.",
    nom:   'Sophie L.',
    lieu:  'Arcachon',
    note:  5,
    date:  'Octobre 2025',
  },
];
---

<section id="temoignages" class="section bg-ink-deep" style="position:relative; overflow:hidden;">
  <!-- Décoration botanique de fond -->
  <div style="position:absolute; right:-60px; bottom:-40px; opacity:0.06; pointer-events:none;" aria-hidden="true">
    <svg width="300" height="400" viewBox="0 0 200 300" fill="none">
      <path d="M100 300 C98 240 102 180 100 120 C98 60 100 20 100 0" stroke="#C9A44A" stroke-width="1.5" stroke-linecap="round"/>
      <path d="M100 260 C82 244 64 234 46 226" stroke="#C9A44A" stroke-width="1" stroke-linecap="round" fill="none"/>
      <path d="M100 260 C120 244 138 235 156 228" stroke="#C9A44A" stroke-width="1" stroke-linecap="round" fill="none"/>
      <path d="M100 220 C80 202 60 192 40 184" stroke="#C9A44A" stroke-width="0.9" stroke-linecap="round" fill="none"/>
      <path d="M100 220 C122 202 142 193 162 186" stroke="#C9A44A" stroke-width="0.9" stroke-linecap="round" fill="none"/>
      <path d="M100 180 C78 160 56 150 36 142" stroke="#C9A44A" stroke-width="0.8" stroke-linecap="round" fill="none"/>
      <path d="M100 180 C124 160 146 151 166 144" stroke="#C9A44A" stroke-width="0.8" stroke-linecap="round" fill="none"/>
      <path d="M100 140 C82 122 64 113 48 106" stroke="#C9A44A" stroke-width="0.7" stroke-linecap="round" fill="none"/>
      <path d="M100 140 C120 122 138 114 154 108" stroke="#C9A44A" stroke-width="0.7" stroke-linecap="round" fill="none"/>
    </svg>
  </div>

  <div class="container" style="position:relative; z-index:1;">

    <!-- Header -->
    <div style="text-align:center; margin-bottom:3.5rem;" data-reveal>
      <span class="section-label">Ce qu'ils disent</span>
      <div class="gold-rule gold-rule-center" style="margin:1rem auto;"></div>
      <h2 style="color:var(--parchment);">
        Ils ont vécu<br>
        <em style="color:var(--gold-base);">l'expérience</em>
      </h2>
    </div>

    <!-- Grille témoignages -->
    <div class="testimonials-grid">
      {temoignages.map((t, i) => (
        <article class="temoignage-card" data-reveal style={`transition-delay:${i * 0.15}s`}>
          <!-- Guillemet décoratif -->
          <div class="quote-mark" aria-hidden="true">"</div>

          <!-- Étoiles -->
          <div class="stars" role="img" aria-label={`${t.note} étoiles sur 5`}>
            {'★'.repeat(t.note)}
          </div>

          <blockquote>
            <p class="temoignage-texte">«&nbsp;{t.texte}&nbsp;»</p>
          </blockquote>

          <footer class="temoignage-footer">
            <div class="temoignage-avatar" aria-hidden="true">
              {t.nom.charAt(0)}
            </div>
            <div>
              <strong class="temoignage-nom">{t.nom}</strong>
              <span class="temoignage-meta">{t.lieu} · {t.date}</span>
            </div>
          </footer>
        </article>
      ))}
    </div>

    <!-- Badge confiance -->
    <div style="text-align:center; margin-top:3.5rem;" data-reveal>
      <div class="trust-badge">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M9 2 L10.8 6.6 L16 7 L12.2 10.4 L13.4 16 L9 13.2 L4.6 16 L5.8 10.4 L2 7 L7.2 6.6 Z"
                stroke="#C9A44A" stroke-width="1" fill="none"/>
        </svg>
        <span>Note moyenne 5/5 — 47 avis vérifiés</span>
      </div>
    </div>
  </div>
</section>

<style>
  .temoignage-card {
    background: rgba(245,240,232,0.05);
    border: 1px solid rgba(201,164,74,0.15);
    border-radius: var(--radius-card);
    padding: 2rem;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color 0.3s ease, background 0.3s ease;
  }
  .temoignage-card:hover {
    background: rgba(245,240,232,0.07);
    border-color: rgba(201,164,74,0.3);
  }

  .quote-mark {
    font-family: var(--font-display);
    font-size: 4.5rem;
    color: var(--gold-base);
    opacity: 0.2;
    line-height: 1;
    position: absolute;
    top: 0.5rem;
    right: 1.5rem;
    font-style: italic;
    user-select: none;
  }

  .temoignage-texte {
    font-size: 0.925rem;
    color: rgba(245,240,232,0.75);
    line-height: 1.8;
    font-style: italic;
    flex: 1;
  }
  blockquote { margin: 0; flex: 1; }

  .temoignage-footer {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(201,164,74,0.1);
    margin-top: auto;
  }

  .temoignage-avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: rgba(201,164,74,0.15);
    border: 1px solid rgba(201,164,74,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--gold-base);
    flex-shrink: 0;
  }

  .temoignage-nom {
    display: block;
    font-family: var(--font-body);
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--parchment);
  }
  .temoignage-meta {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: rgba(245,240,232,0.35);
    letter-spacing: 0.1em;
    margin-top: 0.15rem;
  }

  .trust-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: rgba(201,164,74,0.08);
    border: 1px solid rgba(201,164,74,0.2);
    border-radius: 30px;
    padding: 0.6rem 1.4rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    color: rgba(245,240,232,0.5);
    text-transform: uppercase;
  }
</style>

---
import BaseLayout      from '../layouts/BaseLayout.astro';
import Header          from '../components/Header.astro';
import HeroParallax    from '../components/HeroParallax.astro';
import ServicesRail    from '../components/ServicesRail.astro';
import DinersCalendar  from '../components/DinersCalendar.astro';
import DishGallery        from '../components/DishGallery.astro';
import ChefAbout          from '../components/ChefAbout.astro';
import DistinctionSection from '../components/DistinctionSection.astro';
import StatsBand       from '../components/StatsBand.astro';
import Testimonials    from '../components/Testimonials.astro';
import ReservationCTA  from '../components/ReservationCTA.astro';
import Footer          from '../components/Footer.astro';
---

<BaseLayout
  title="Bris'Art Culinaire — Restaurant Gastronomique & Cours de Cuisine La Baule | Bib Gourmand Michelin 2026"
  description="Guillaume Brisard, chef Bib Gourmand Michelin 2026, vous accueille à La Baule pour un restaurant gastronomique, des cours de cuisine et des événements sur-mesure."
  canonical="https://www.brisartculinaire.fr/"
>
  <Header transparent />
  <main>
    <HeroParallax />
    <ServicesRail />

    <!-- Galerie plats OGL (FIX 3) -->
    <section class="gallery-section">
      <div class="container">
        <p class="gallery-title" data-reveal>Chaque assiette, une signature</p>
      </div>
      <div class="gallery-canvas-wrapper">
        <DishGallery />
      </div>
    </section>

    <!-- Chef à domicile parallax (FIX 5) -->
    <section class="chef-parallax-section">
      <div class="chef-parallax-overlay"></div>
      <div class="chef-parallax-content" data-reveal>
        <span class="section-label" style="color:rgba(255,255,255,0.6);">Événement privé</span>
        <div class="gold-rule" style="margin:1rem 0;"></div>
        <h2 style="color:#fff; margin-bottom:1rem;">Envie de privatiser<br><em style="color:var(--gold-base);">le chef ?</em></h2>
        <p style="color:rgba(255,255,255,0.75); max-width:480px; margin-bottom:2rem; line-height:1.75;">
          Dîner en villa, anniversaire gastronomique, team building culinaire :
          Guillaume se déplace et crée une expérience unique, rien que pour vous.
        </p>
        <a href="/chef-a-domicile" class="btn-gold">Découvrir l'offre</a>
      </div>
    </section>

    <ChefAbout />
    <DinersCalendar />
    <DistinctionSection />

    <StatsBand />
    <Testimonials />
    <ReservationCTA />
  </main>
  <Footer />
</BaseLayout>

<style>
  /* ── Galerie plats ── */
  .gallery-section {
    background: var(--ink-deep, #0f0e0b);
    padding: 2rem 0 0;
    overflow: hidden;
  }
  .gallery-title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    color: var(--gold-base);
    text-align: center;
    letter-spacing: 0.04em;
    margin-bottom: 2rem;
  }
  .gallery-canvas-wrapper {
    width: 100%;
  }

  /* ── Chef à domicile parallax ── */
  .chef-parallax-section {
    position: relative;
    min-height: 520px;
    display: flex;
    align-items: center;
    background-image: url('/images/guillaume/platlanding.webp');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
  }
  .chef-parallax-overlay {
    position: absolute;
    inset: 0;
    background: rgba(15, 14, 11, 0.58);
  }
  .chef-parallax-content {
    position: relative;
    z-index: 1;
    padding: clamp(3rem, 6vw, 5rem) clamp(1.5rem, 5vw, 4rem);
    max-width: 640px;
  }
</style>

---
const cards = [
  {
    title: 'Pour qui ?',
    text: 'Adultes, adolescents, enfants à partir de 10 ans, en individuel ou en famille. Parlons ensemble pour voir quelle est la meilleure manière de commencer.',
    icon: `
      <circle cx="12" cy="4" r="1.5" fill="#1a7fa0"/>
      <circle cx="4" cy="18" r="1.5" fill="#1a7fa0"/>
      <circle cx="20" cy="18" r="1.5" fill="#1a7fa0"/>
      <line x1="12" y1="4" x2="4" y2="18" stroke="#1a7fa0" stroke-width="0.8" opacity="0.6"/>
      <line x1="12" y1="4" x2="20" y2="18" stroke="#1a7fa0" stroke-width="0.8" opacity="0.6"/>
      <line x1="4" y1="18" x2="20" y2="18" stroke="#1a7fa0" stroke-width="0.8" opacity="0.6"/>`,
  },
  {
    title: 'Comment ?',
    text: "Par l'Hypnose, la Trame, le Linequartz et la PNL, en accompagnement ou en complément d'un suivi médical. Chaque protocole est adapté à votre situation.",
    icon: `
      <ellipse cx="12" cy="12" rx="10" ry="4" fill="none" stroke="#1a7fa0" stroke-width="0.8" opacity="0.7"/>
      <circle cx="12" cy="12" r="3" fill="none" stroke="#f0c060" stroke-width="1"/>
      <circle cx="22" cy="12" r="1.5" fill="#1a7fa0"/>`,
  },
  {
    title: 'Pour quoi ?',
    text: "Dépression, angoisses, douleurs, blocages, stress, phobies, migraines, deuils, arrêt du tabac, perte de poids, surmenage, manque de confiance en soi, addictions...",
    icon: `
      <path d="M12 12 Q16 8 20 12 Q16 16 12 12 Q8 8 4 12 Q8 16 12 12" fill="none" stroke="#1a7fa0" stroke-width="0.8" opacity="0.7"/>
      <circle cx="12" cy="12" r="2" fill="#f0c060"/>
      <circle cx="12" cy="12" r="1" fill="#1a7fa0"/>`,
  },
];
---
<section id="pour-qui" class="relative py-24 bg-[#e8f4f8] overflow-hidden">
  <div class="max-w-5xl mx-auto px-6 text-center">
    <span class="text-[#1a7fa0] text-xs tracking-[0.2em] uppercase font-sans block mb-3">Comprendre la démarche</span>
    <h2 class="font-serif font-light text-[#1a3a4a] mb-4 break-words hyphens-auto" style="font-size: clamp(1.6rem, 3.5vw, 2.8rem);">
      Qui consulte, <em class="text-[#c49040] not-italic">comment</em> et pour quoi ?
    </h2>
    <p class="text-[#1a3a4a]/65 max-w-xl mx-auto mb-14 font-sans" style="font-size: 1.05rem;">
      L'hypnothérapie s'adresse à tous ceux qui souhaitent retrouver leur équilibre intérieur.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {cards.map(card => (
        <div class="glow-biolum group relative rounded-2xl overflow-hidden border border-[#1a7fa0]/20 bg-white/80 backdrop-blur-sm p-8 text-center transition-all duration-500 hover:bg-[#ddeef5] hover:shadow-lg hover:shadow-[#1a7fa0]/20">
          <div class="absolute top-0 right-0 w-20 h-20 bg-gradient-to-bl from-[#4db8d4]/15 to-transparent rounded-bl-full opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="w-16 h-16 mx-auto mb-5 rounded-full flex items-center justify-center border border-[#1a7fa0]/25" style="background: rgba(26,127,160,0.06);">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <Fragment set:html={card.icon} />
            </svg>
          </div>
          <h3 class="font-serif text-xl text-[#1a7fa0] mb-3">{card.title}</h3>
          <p class="text-[#1a3a4a]/70 text-sm leading-relaxed font-sans">{card.text}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Vague vers Therapies -->
  <div class="absolute bottom-0 left-0 right-0 pointer-events-none">
    <svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" class="w-full" style="display:block;">
      <path d="M0,30 C480,60 960,0 1440,30 L1440,60 L0,60 Z" fill="#e8f4f8"/>
    </svg>
  </div>
</section>

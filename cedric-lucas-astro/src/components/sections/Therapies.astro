---
const therapies = [
  {
    name: 'Hypnose',
    meta: '~60 min · Au cas par cas',
    price: '90',
    icon: `<circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>`,
    desc: "Hypnose Au Cœur de Soi : une méthode douce pour découvrir que « tout est en soi ». Arrêt du tabac, perte de poids, sommeil, dépression, angoisses, phobies, douleurs, blocages, migraines, deuil.",
  },
  {
    name: 'EMDR',
    meta: '~90 min · Au cas par cas',
    price: '90',
    icon: `<path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/>`,
    desc: "Désensibilisation et Retraitement par les Mouvements Oculaires. Approche reconnue pour le traitement des traumatismes, chocs émotionnels et deuils.",
  },
  {
    name: 'PNL',
    meta: '~90 min · 5 à 8 séances',
    price: '80',
    icon: `<path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18"/>`,
    desc: "Techniques avancées de communication et de changement de comportement. Gestion du stress, amélioration des performances, développement personnel et professionnel.",
  },
  {
    name: 'La Trame',
    meta: '~60 min · Espacées 3 semaines',
    price: '65',
    icon: `<path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>`,
    desc: "Évacuation du surplus d'émotions. Retour à la capacité de faire des choix, de prendre des décisions et de retrouver le meilleur de soi-même.",
  },
  {
    name: 'Linequartz',
    meta: '~30 min · Protocole 4 semaines',
    price: '50',
    icon: `<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>`,
    desc: "Stimulation des centres énergétiques par l'envoi de spectres lumineux dépourvus d'infrarouge. Association bénéfique avec chronobiologie, phytothérapie et micronutrition.",
  },
];
---
<!-- Ancre tarifs pour la nav -->
<div id="tarifs" style="position:absolute; margin-top:-80px;"></div>

<section id="therapies" class="relative overflow-hidden isolate" style="padding-top:6rem; padding-bottom:6rem;">

  <!-- Vidéo mer en background — z-index:0 -->
  <video
    autoplay muted loop playsinline
    class="absolute inset-0 w-full h-full object-cover"
    style="z-index:0; opacity:0.5; filter: saturate(0.8) hue-rotate(160deg);">
    <source media="(max-width: 768px)" src="/video-mobile.mp4" type="video/mp4">
    <source src="/video.mp4" type="video/mp4">
  </video>

  <!-- Overlay lumineux marin — z-index:1 -->
  <div class="absolute inset-0" style="z-index:1; background: linear-gradient(to bottom, rgba(240,248,251,0.85) 0%, rgba(232,244,248,0.75) 20%, rgba(232,244,248,0.75) 80%, rgba(240,248,251,0.85) 100%);"></div>

  <!-- Vague entrante (depuis PourQui → e8f4f8) -->
  <div class="absolute top-0 left-0 right-0" style="z-index:2;">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full" style="display:block;">
      <path d="M0,30 C480,60 960,0 1440,30 L1440,0 L0,0 Z" fill="#e8f4f8"/>
    </svg>
  </div>

  <!-- Contenu -->
  <div class="relative max-w-5xl mx-auto px-6 text-center" style="z-index:10;">

    <span class="text-[#1a7fa0] text-xs tracking-[0.2em] uppercase font-sans block mb-3">Méthodes & honoraires</span>
    <h2 class="font-serif font-light text-[#1a3a4a] mb-4" style="font-size: clamp(1.8rem, 3.5vw, 2.8rem);">
      Les <em class="text-[#c49040] not-italic">thérapies proposées</em>
    </h2>
    <p class="text-[#1a3a4a]/60 max-w-xl mx-auto mb-14 font-sans">
      Chaque approche est choisie en fonction de votre situation. Certaines se complètent naturellement.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {therapies.map(t => (
        <div class="glow-biolum relative group rounded-2xl overflow-hidden border border-[#1a7fa0]/20 bg-white/80 backdrop-blur-sm p-6 text-left transition-all duration-500 hover:border-[#1a7fa0]/50 hover:bg-[#e8f4f8] hover:shadow-lg hover:shadow-[#1a7fa0]/20">

          <!-- Lueur coin -->
          <div class="absolute top-0 right-0 w-20 h-20 bg-gradient-to-bl from-[#4db8d4]/15 to-transparent rounded-bl-full opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

          <!-- Icône -->
          <div class="w-12 h-12 mb-4 rounded-full flex items-center justify-center border border-[#c49040]/30" style="background: rgba(196,144,64,0.08);">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#c49040" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <Fragment set:html={t.icon} />
            </svg>
          </div>

          <!-- Prix badge -->
          <span class="inline-block px-3 py-1 rounded-full bg-[#f0c060]/20 border border-[#c49040]/30 text-[#c49040] text-xs tracking-wider mb-4 font-sans">
            {t.price}€ / séance
          </span>

          <h3 class="font-serif text-xl text-[#1a3a4a] mb-1">{t.name}</h3>
          <p class="text-[#2d6a80]/70 text-xs mb-3 font-sans">{t.meta}</p>
          <p class="text-[#1a3a4a]/75 text-sm leading-relaxed font-sans">{t.desc}</p>
        </div>
      ))}
    </div>

    <div class="mt-12">
      <a
        href="tel:0678825558"
        class="inline-block font-semibold py-4 px-10 rounded-full text-sm tracking-widest uppercase transition-all duration-300 font-sans text-white hover:shadow-lg hover:shadow-[#1a7fa0]/30"
        style="background: linear-gradient(135deg, #1a7fa0, #4db8d4);">
        Prendre rendez-vous — 06 78 82 55 58
      </a>
    </div>
  </div>

  <!-- Vague sortante vers Presentation (ddeef5) -->
  <div class="absolute bottom-0 left-0 right-0" style="z-index:10;">
    <svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" class="w-full" style="display:block;">
      <path d="M0,30 C480,0 960,60 1440,30 L1440,60 L0,60 Z" fill="#ddeef5"/>
    </svg>
  </div>
</section>

---
---
<section id="contact" class="relative py-24 bg-gradient-to-b from-[#e8f4f8] to-[#f5ecd6]">
  <div class="relative z-10" style="pointer-events:auto;">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-12">
        <span class="text-[#1a7fa0] text-xs tracking-[0.2em] uppercase font-sans block mb-3">Prendre rendez-vous</span>
        <h2 class="font-serif font-light text-[#1a3a4a] mb-4" style="font-size: clamp(1.8rem, 3.5vw, 2.8rem);">
          Entrons en <em class="text-[#c49040] not-italic">contact</em>
        </h2>
        <p class="text-[#1a3a4a]/60 max-w-xl mx-auto font-sans">
          Je réponds généralement dans la journée. N'hésitez pas à m'appeler directement.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-[1fr_1.6fr] gap-12 items-start">

        <!-- Coordonnées -->
        <div>
          <h3 class="font-serif text-xl text-[#c49040] mb-6">Coordonnées</h3>

          <div class="flex items-start gap-4 mb-5">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#7C9A7E" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 mt-0.5">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.41a2 2 0 0 1 1.99-2.18h3a2 2 0 0 1 2 1.72c.127.96.36 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6.19 6.19l.87-.87a2 2 0 0 1 2.11-.45c.907.34 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            <div>
              <a href="tel:0678825558" class="text-[#c49040] font-semibold text-xl hover:text-[#d4a050] transition-colors font-sans">06 78 82 55 58</a>
              <p class="text-[#1a3a4a]/55 text-sm font-sans">Appel ou SMS bienvenu</p>
            </div>
          </div>

          <div class="flex items-start gap-4 mb-5">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#7C9A7E" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 mt-0.5">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
            </svg>
            <a href="mailto:cedricenr@gmail.com" class="text-[#1a3a4a]/80 hover:text-[#c49040] transition-colors font-sans">cedricenr@gmail.com</a>
          </div>

          <div class="flex items-start gap-4">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#7C9A7E" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 mt-0.5">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
            </svg>
            <div>
              <p class="text-[#1a3a4a]/80 font-sans">Saint-André-des-Eaux</p>
              <p class="text-[#1a3a4a]/55 text-sm font-sans">Loire-Atlantique (44)</p>
            </div>
          </div>
        </div>

        <!-- Formulaire -->
        <form
          action="mailto:cedricenr@gmail.com"
          method="get"
          enctype="text/plain"
          class="bg-white/70 border border-[#1a7fa0]/25 rounded-xl p-8 backdrop-blur-sm"
        >
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
            <div>
              <label class="block text-[#1a3a4a]/55 text-xs uppercase tracking-wider mb-1.5 font-sans" for="prenom">Prénom</label>
              <input type="text" id="prenom" name="prenom" placeholder="Votre prénom"
                class="w-full bg-white border border-[#1a7fa0]/30 rounded-lg px-4 py-3 text-[#1a3a4a] text-sm font-sans outline-none focus:border-[#1a7fa0] transition-colors" />
            </div>
            <div>
              <label class="block text-[#1a3a4a]/55 text-xs uppercase tracking-wider mb-1.5 font-sans" for="telephone">Téléphone</label>
              <input type="tel" id="telephone" name="telephone" placeholder="06 XX XX XX XX"
                class="w-full bg-white border border-[#1a7fa0]/30 rounded-lg px-4 py-3 text-[#1a3a4a] text-sm font-sans outline-none focus:border-[#1a7fa0] transition-colors" />
            </div>
          </div>

          <div class="mb-4">
            <label class="block text-[#1a3a4a]/55 text-xs uppercase tracking-wider mb-1.5 font-sans" for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="votre@email.fr"
              class="w-full bg-white border border-[#1a7fa0]/30 rounded-lg px-4 py-3 text-[#1a3a4a] text-sm font-sans outline-none focus:border-[#1a7fa0] transition-colors" />
          </div>

          <div class="mb-4">
            <label class="block text-[#1a3a4a]/55 text-xs uppercase tracking-wider mb-1.5 font-sans" for="motif">Motif de consultation</label>
            <select id="motif" name="motif"
              class="w-full bg-white border border-[#1a7fa0]/30 rounded-lg px-4 py-3 text-[#1a3a4a] text-sm font-sans outline-none focus:border-[#1a7fa0] transition-colors appearance-none">
              <option value="">Choisissez un motif</option>
              <option>Stress / Anxiété</option>
              <option>Arrêt du tabac</option>
              <option>Addictions</option>
              <option>Phobies</option>
              <option>Troubles du sommeil</option>
              <option>Perte de poids</option>
              <option>Deuil / Traumatisme</option>
              <option>Confiance en soi</option>
              <option>Dépression</option>
              <option>Autre</option>
            </select>
          </div>

          <div class="mb-5">
            <label class="block text-[#1a3a4a]/55 text-xs uppercase tracking-wider mb-1.5 font-sans" for="message">Message (optionnel)</label>
            <textarea id="message" name="body" rows="4" placeholder="Décrivez brièvement votre situation si vous le souhaitez..."
              class="w-full bg-white border border-[#1a7fa0]/30 rounded-lg px-4 py-3 text-[#1a3a4a] text-sm font-sans outline-none focus:border-[#1a7fa0] transition-colors resize-y"></textarea>
          </div>

          <button type="submit"
            class="w-full font-semibold py-3.5 rounded-lg text-sm tracking-wide transition-all duration-200 hover:opacity-85 font-sans text-white"
            style="background: linear-gradient(135deg, #7C9A7E, #5a7d5c);">
            Envoyer ma demande
          </button>
        </form>

      </div>
    </div>
  </div>
</section>

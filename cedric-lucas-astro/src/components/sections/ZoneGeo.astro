---
const zones = [
  'Saint-André-des-Eaux','Guérande','La Baule','Saint-Nazaire',
  'Herbignac','Pontchâteau','La Roche-Bernard','Pornichet',
  'Le Croisic','Savenay','En visio — toute France',
];
---
<section class="relative py-24 bg-[#e8f4f8]">
  <div class="max-w-5xl mx-auto px-6 text-center">
    <span class="text-[#1a7fa0] text-xs tracking-[0.2em] uppercase font-sans block mb-3">Où me consulter ?</span>
    <h2 class="font-serif font-light text-[#1a3a4a] mb-4" style="font-size: clamp(1.8rem, 3.5vw, 2.8rem);">
      Zone d'<em class="text-[#c49040] not-italic">intervention</em>
    </h2>
    <p class="text-[#1a3a4a]/60 max-w-xl mx-auto mb-8 font-sans">
      Cabinet basé à Saint-André-des-Eaux, entre mer et brière. Interventions dans un rayon de 30 km autour de Guérande, et en visio sur toute la France.
    </p>

    <!-- Tags communes -->
    <div class="flex flex-wrap gap-2 justify-center mb-10" aria-label="Communes desservies">
      {zones.map(z => (
        <span class="bg-[#1a7fa0]/8 border border-[#1a7fa0]/25 text-[#1a3a4a]/65 text-xs px-3 py-1.5 rounded-full font-sans hover:text-[#1a7fa0] hover:border-[#1a7fa0]/50 transition-colors duration-200">{z}</span>
      ))}
    </div>

    <!-- Carte Google Maps — mode clair -->
    <div class="rounded-2xl overflow-hidden border border-[#1a7fa0]/20">
      <iframe
        src="https://maps.google.com/maps?q=Saint-Andr%C3%A9-des-Eaux,44140,France&t=&z=11&ie=UTF8&iwloc=&output=embed"
        width="100%"
        height="420"
        style="border:0; display:block;"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Zone d'intervention Cédric Lucas — Saint-André-des-Eaux et alentours"
      ></iframe>
    </div>
  </div>

  <!-- Vague vers Reseaux (f0f8fb) -->
  <div class="absolute bottom-0 left-0 right-0">
    <svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" class="w-full" style="display:block;">
      <path d="M0,30 C480,0 960,60 1440,30 L1440,60 L0,60 Z" fill="#f0f8fb"/>
    </svg>
  </div>
</section>

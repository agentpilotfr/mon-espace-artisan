---
---
<header class="fixed top-0 left-0 right-0 z-50">

  <nav class="mx-4 mt-4 rounded-2xl border border-[#1a7fa0]/20 backdrop-blur-xl shadow-lg shadow-[#1a3a4a]/10"
    style="background: rgba(255,255,255,0.85);"
    role="navigation" aria-label="Navigation principale">

    <div class="flex items-center justify-between px-6 py-4">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group">
        <img
          src="/logocedric.svg"
          alt="Cédric Lucas Hypnothérapeute"
          width="48"
          height="48"
          class="shrink-0 group-hover:opacity-80 transition-opacity duration-300" />
        <div>
          <span class="font-serif text-[#1a3a4a] text-lg group-hover:text-[#2d7d9a] transition-colors duration-300">
            Cédric Lucas
          </span>
          <span class="block text-[#2d7d9a] text-[10px] tracking-[0.2em] uppercase font-sans leading-none mt-0.5">
            Hypnothérapeute
          </span>
        </div>
      </a>

      <!-- Nav desktop -->
      <div class="hidden md:flex items-center gap-8">
        <a href="#therapies"
          class="text-[#1a3a4a]/70 hover:text-[#1a7fa0] text-sm tracking-wide transition-colors duration-300 hover:drop-shadow-[0_0_8px_rgba(26,127,160,0.5)]">
          Thérapies
        </a>
        <a href="#tarifs"
          class="text-[#1a3a4a]/70 hover:text-[#1a7fa0] text-sm tracking-wide transition-colors duration-300 hover:drop-shadow-[0_0_8px_rgba(26,127,160,0.5)]">
          Tarifs
        </a>
        <a href="#presentation"
          class="text-[#1a3a4a]/70 hover:text-[#1a7fa0] text-sm tracking-wide transition-colors duration-300 hover:drop-shadow-[0_0_8px_rgba(26,127,160,0.5)]">
          À propos
        </a>
        <a href="#contact"
          class="text-[#1a3a4a]/70 hover:text-[#1a7fa0] text-sm tracking-wide transition-colors duration-300 hover:drop-shadow-[0_0_8px_rgba(26,127,160,0.5)]">
          Contact
        </a>
      </div>

      <!-- CTA + Hamburger -->
      <div class="flex items-center gap-4">
        <a href="tel:0678825558"
          class="hidden sm:flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-medium transition-all duration-300 shadow-md hover:shadow-[#1a7fa0]/40 tracking-wide text-white"
          style="background: linear-gradient(135deg, #1a7fa0, #4db8d4);">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1l-2.3 2.2z"/>
          </svg>
          Rendez-vous
        </a>

        <!-- Hamburger mobile -->
        <button
          id="menu-btn"
          aria-label="Ouvrir le menu"
          aria-expanded="false"
          class="md:hidden flex flex-col gap-1.5 cursor-pointer p-2 z-[1001] relative"
          style="background:none; border:none;">
          <span class="nav-bar block w-5 h-px bg-[#1a3a4a]/70 rounded transition-all duration-300"></span>
          <span class="nav-bar block w-5 h-px bg-[#1a3a4a]/70 rounded transition-all duration-300"></span>
          <span class="nav-bar block w-5 h-px bg-[#1a3a4a]/70 rounded transition-all duration-300"></span>
        </button>
      </div>
    </div>

    <!-- Menu mobile — expand par JS (max-height:0 → scrollHeight) -->
    <div id="mobile-menu"
      class="md:hidden overflow-hidden border-t border-[#1a3a4a]/10 transition-all duration-500 ease-in-out"
      style="max-height:0;">
      <div class="px-6 py-6 flex flex-col gap-6">
        <a href="#therapies" class="mob-link text-[#1a3a4a]/70 hover:text-[#1a7fa0] text-sm tracking-wider uppercase transition-colors">Thérapies</a>
        <a href="#tarifs"    class="mob-link text-[#1a3a4a]/70 hover:text-[#1a7fa0] text-sm tracking-wider uppercase transition-colors">Tarifs</a>
        <a href="#presentation" class="mob-link text-[#1a3a4a]/70 hover:text-[#1a7fa0] text-sm tracking-wider uppercase transition-colors">À propos</a>
        <a href="#contact"  class="mob-link text-[#1a3a4a]/70 hover:text-[#1a7fa0] text-sm tracking-wider uppercase transition-colors">Contact</a>
        <a href="tel:0678825558"
          class="mob-link inline-flex items-center justify-center gap-2 px-6 py-3 rounded-full text-sm font-medium text-white tracking-wide"
          style="background: linear-gradient(135deg, #1a7fa0, #4db8d4);">
          📞 06 78 82 55 58
        </a>
      </div>
    </div>

  </nav>
</header>

<style>
  #menu-btn.open .nav-bar:nth-child(1) { transform: rotate(45deg) translateY(8px); }
  #menu-btn.open .nav-bar:nth-child(2) { opacity: 0; }
  #menu-btn.open .nav-bar:nth-child(3) { transform: rotate(-45deg) translateY(-8px); }
</style>

<script>
  var btn = document.getElementById('menu-btn');
  var menu = document.getElementById('mobile-menu');
  var isOpen = false;

  function openMenu() {
    isOpen = true;
    menu.style.maxHeight = menu.scrollHeight + 'px';
    btn.classList.add('open');
    btn.setAttribute('aria-expanded', 'true');
  }

  function closeMenu() {
    isOpen = false;
    menu.style.maxHeight = '0';
    btn.classList.remove('open');
    btn.setAttribute('aria-expanded', 'false');
  }

  if (btn) {
    btn.addEventListener('click', function() {
      if (isOpen) { closeMenu(); } else { openMenu(); }
    });
  }

  if (menu) {
    var links = menu.querySelectorAll('.mob-link');
    for (var i = 0; i < links.length; i++) {
      links[i].addEventListener('click', closeMenu);
    }
  }
</script>

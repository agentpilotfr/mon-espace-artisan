---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import PourQui from '../components/sections/PourQui.astro';
import Therapies from '../components/sections/Therapies.astro';
import Presentation from '../components/sections/Presentation.astro';
import Temoignages from '../components/sections/Temoignages.astro';
import Disclaimer from '../components/sections/Disclaimer.astro';
import ZoneGeo from '../components/sections/ZoneGeo.astro';
import Reseaux from '../components/sections/Reseaux.astro';
import Contact from '../components/sections/Contact.astro';

const seo = {
  title: 'Cédric Lucas — Hypnothérapeute Saint-André-des-Eaux (44)',
  description: 'Cédric Lucas, hypnothérapeute diplômé à Saint-André-des-Eaux (44). Hypnose, PNL, EMDR, La Trame, Linequartz. Stress, phobies, addictions, arrêt tabac. 06 78 82 55 58',
};
---
<BaseLayout title={seo.title} description={seo.description}>
  <Navbar />
  <main>
    <Hero />
    <PourQui />
    <Therapies />
    <Presentation />
    <Temoignages />
    <Disclaimer />
    <ZoneGeo />
    <Reseaux />
    <Contact />
  </main>
  <Footer />
</BaseLayout>

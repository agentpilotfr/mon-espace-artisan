---
import { SITE } from '../config';

const navLinks = [
  { href: '/', label: 'Accueil' },
  { href: '/tarifs', label: 'Tarifs' },
  { href: '/templates', label: 'Templates' },
  { href: '/artisans', label: 'Nos métiers' },
  { href: '/a-propos', label: 'À propos' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header
  class="sticky top-0 z-50 w-full"
  style="background-color: var(--color-cream); border-bottom: 1px solid rgba(15,30,61,0.08);"
  x-data="{ open: false }"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center justify-between h-16 md:h-20">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 flex-shrink-0 group" aria-label="Mon Espace Artisan — Accueil">
      <span
        class="flex items-center justify-center w-9 h-9 rounded-lg text-white text-sm font-bold transition-transform group-hover:scale-105"
        style="background-color: var(--color-terra);"
        aria-hidden="true"
      >
        MEA
      </span>
      <span class="text-lg font-semibold leading-tight hidden sm:block" style="font-family: var(--font-fraunces); color: var(--color-navy);">
        Mon Espace<br class="hidden lg:block" />
        <span style="color: var(--color-terra);">Artisan</span>
      </span>
    </a>

    <!-- Nav desktop -->
    <nav class="hidden md:flex items-center gap-1" aria-label="Navigation principale">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${
            currentPath === href
              ? 'font-semibold'
              : 'hover:bg-gray-100'
          }`}
          style={currentPath === href
            ? 'color: var(--color-terra);'
            : 'color: var(--color-navy);'}
          aria-current={currentPath === href ? 'page' : undefined}
        >
          {label}
        </a>
      ))}
    </nav>

    <!-- CTA desktop -->
    <div class="hidden md:flex items-center gap-3">
      <a href={`tel:${SITE.phone}`} class="flex items-center gap-1.5 text-sm font-medium" style="color: var(--color-navy);">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.99 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.9 1.17h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 5.99 5.99l1.07-1.07a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        {SITE.phoneDisplay}
      </a>
      <a href={SITE.calendly} class="btn-primary text-sm py-2.5 px-5">
        Prendre RDV gratuit
      </a>
    </div>

    <!-- Burger mobile -->
    <button
      class="md:hidden flex items-center justify-center w-10 h-10 rounded-lg"
      style="color: var(--color-navy);"
      @click="open = !open"
      :aria-expanded="open"
      aria-controls="mobile-menu"
      aria-label="Ouvrir le menu"
    >
      <svg x-show="!open" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
      <svg x-show="open" x-cloak xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <!-- Menu mobile -->
  <div
    id="mobile-menu"
    x-show="open"
    x-cloak
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 -translate-y-2"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100 translate-y-0"
    x-transition:leave-end="opacity-0 -translate-y-2"
    class="md:hidden border-t"
    style="background-color: var(--color-cream); border-color: rgba(15,30,61,0.08);"
  >
    <nav class="max-w-6xl mx-auto px-4 py-4 flex flex-col gap-1" aria-label="Navigation mobile">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class="px-4 py-3 rounded-lg text-base font-medium"
          style={currentPath === href
            ? 'color: var(--color-terra); background-color: rgba(217,116,67,0.08);'
            : 'color: var(--color-navy);'}
          @click="open = false"
        >
          {label}
        </a>
      ))}
      <div class="mt-4 pt-4 flex flex-col gap-3" style="border-top: 1px solid rgba(15,30,61,0.08);">
        <a href={`tel:${SITE.phone}`} class="flex items-center gap-2 px-4 py-3 text-base font-semibold" style="color: var(--color-navy);">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.99 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.9 1.17h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 5.99 5.99l1.07-1.07a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          {SITE.phoneDisplay}
        </a>
        <a href={SITE.calendly} class="btn-primary text-center">
          Prendre RDV gratuit
        </a>
      </div>
    </nav>
  </div>
</header>

<style>
  [x-cloak] { display: none !important; }
</style>

---
import { SITE } from '../config';
const year = new Date().getFullYear();
---

<footer style="background-color: var(--color-navy); color: rgba(250,247,242,0.85);">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-14 md:py-16">

    <!-- Grille principale -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Colonne 1 : Marque -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="inline-flex items-center gap-2 mb-4 group" aria-label="Mon Espace Artisan">
          <span
            class="flex items-center justify-center w-9 h-9 rounded-lg text-white text-xs font-bold"
            style="background-color: var(--color-terra);"
          >
            MEA
          </span>
          <span class="text-lg font-semibold" style="font-family: var(--font-fraunces); color: var(--color-cream);">
            Mon Espace Artisan
          </span>
        </a>
        <p class="text-sm leading-relaxed mb-2" style="color: rgba(250,247,242,0.65);">
          Votre site internet en 24h, créé par un humain de Saint-Nazaire.
          Sans jargon, sans engagement.
        </p>
<a href={`tel:${SITE.phone}`} class="inline-flex items-center gap-2 text-sm font-semibold" style="color: var(--color-terra);">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.99 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.9 1.17h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 5.99 5.99l1.07-1.07a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          {SITE.phoneDisplay}
        </a>
      </div>

      <!-- Colonne 2 : Navigation -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-widest mb-4" style="color: var(--color-cream);">Navigation</h3>
        <ul class="flex flex-col gap-2.5">
          <li><a href="/" class="text-sm hover:text-white transition-colors" style="color: rgba(250,247,242,0.65);">Accueil</a></li>
          <li><a href="/tarifs" class="text-sm hover:text-white transition-colors" style="color: rgba(250,247,242,0.65);">Tarifs</a></li>
          <li><a href="/artisans" class="text-sm hover:text-white transition-colors" style="color: rgba(250,247,242,0.65);">Nos métiers</a></li>
          <li><a href="/a-propos" class="text-sm hover:text-white transition-colors" style="color: rgba(250,247,242,0.65);">À propos</a></li>
          <li><a href="/contact" class="text-sm hover:text-white transition-colors" style="color: rgba(250,247,242,0.65);">Contact</a></li>
        </ul>
      </div>

      <!-- Colonne 3 : Métiers -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-widest mb-4" style="color: var(--color-cream);">Métiers</h3>
        <ul class="flex flex-col gap-2.5">
          <li><a href="/artisans#plombier" class="text-sm hover:text-white transition-colors" style="color: rgba(250,247,242,0.65);">Plombier</a></li>
          <li><a href="/artisans#electricien" class="text-sm hover:text-white transition-colors" style="color: rgba(250,247,242,0.65);">Électricien</a></li>
          <li><a href="/artisans#peintre" class="text-sm hover:text-white transition-colors" style="color: rgba(250,247,242,0.65);">Peintre</a></li>
          <li><a href="/artisans#menuisier" class="text-sm hover:text-white transition-colors" style="color: rgba(250,247,242,0.65);">Menuisier</a></li>
          <li><a href="/artisans#couvreur" class="text-sm hover:text-white transition-colors" style="color: rgba(250,247,242,0.65);">Couvreur</a></li>
          <li><a href="/artisans#paysagiste" class="text-sm hover:text-white transition-colors" style="color: rgba(250,247,242,0.65);">Paysagiste</a></li>
        </ul>
      </div>

      <!-- Colonne 4 : CTA -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-widest mb-4" style="color: var(--color-cream);">Prêt à démarrer ?</h3>
        <p class="text-sm mb-4 leading-relaxed" style="color: rgba(250,247,242,0.65);">
          Un appel de 15 minutes suffit. Gratuit, sans engagement.
        </p>
        <a href={SITE.calendly} class="btn-primary text-sm py-2.5 w-full justify-center">
          Réserver mon créneau
        </a>
        <p class="text-xs mt-3 text-center" style="color: rgba(250,247,242,0.45);">
          {SITE.hours}
        </p>
      </div>
    </div>

    <!-- Maillage SEO local -->
    <div class="mt-12 pt-8" style="border-top: 1px solid rgba(250,247,242,0.08);">
      <p class="text-xs font-semibold uppercase tracking-wider mb-3" style="color: rgba(250,247,242,0.6);">
        Zones d'intervention — Loire-Atlantique (44)
      </p>
      <nav class="flex flex-wrap gap-x-2 gap-y-1" aria-label="Création de site web par ville">
        {[
          { label: 'Création de site web Saint-Nazaire',        slug: 'saint-nazaire' },
          { label: 'Création de site web Pornichet',            slug: 'pornichet' },
          { label: 'Création de site web La Baule',             slug: 'la-baule' },
          { label: 'Création de site web Guérande',             slug: 'guerande' },
          { label: 'Création de site web Trignac',              slug: 'trignac' },
          { label: 'Création de site web Montoir-de-Bretagne',  slug: 'montoir-de-bretagne' },
          { label: 'Création de site web Pontchâteau',          slug: 'pontchateau' },
          { label: 'Création de site web Savenay',              slug: 'savenay' },
          { label: 'Création de site web Saint-Joachim',        slug: 'saint-joachim' },
          { label: 'Création de site web Saint-Brevin-les-Pins',slug: 'saint-brevin-les-pins' },
          { label: 'Création de site web Saint-Malo-de-Guersac',slug: 'saint-malo-de-guersac' },
          { label: 'Création de site web Donges',               slug: 'donges' },
          { label: 'Création de site web Herbignac',            slug: 'herbignac' },
          { label: 'Création de site web Besné',                slug: 'besne' },
          { label: 'Création de site web La Chapelle-des-Marais',slug: 'la-chapelle-des-marais' },
          { label: 'Création de site web Paimboeuf',            slug: 'paimboeuf' },
          { label: 'Création de site web Saint-André-des-Eaux', slug: 'saint-andre-des-eaux' },
          { label: 'Création de site web Le Pouliguen',         slug: 'le-pouliguen' },
          { label: 'Création de site web Batz-sur-Mer',         slug: 'batz-sur-mer' },
          { label: 'Création de site web Le Croisic',           slug: 'le-croisic' },
        ].map(({ label, slug }, i, arr) => (
          <span class="text-xs" style="color: rgba(250,247,242,0.35);">
            <a href={`/creation-site-web-${slug}`} class="hover:text-white transition-colors" style="color: rgba(250,247,242,0.35);">{label}</a>{i < arr.length - 1 ? <span aria-hidden="true"> ·</span> : null}
          </span>
        ))}
      </nav>
    </div>

    <!-- Séparateur -->
    <div class="mt-8 pt-8" style="border-top: 1px solid rgba(250,247,242,0.1);">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-xs" style="color: rgba(250,247,242,0.4);">
          © {year} {SITE.ownerName} — Mon Espace Artisan · {SITE.address} ({SITE.postalCode}) · SIRET {SITE.siret}
        </p>
        <nav class="flex items-center gap-4 flex-wrap justify-center" aria-label="Liens légaux">
          <a href="/mentions-legales" class="text-xs hover:text-white transition-colors" style="color: rgba(250,247,242,0.4);">Mentions légales</a>
          <a href="/cgv" class="text-xs hover:text-white transition-colors" style="color: rgba(250,247,242,0.4);">CGV</a>
          <a href="/confidentialite" class="text-xs hover:text-white transition-colors" style="color: rgba(250,247,242,0.4);">Confidentialité</a>
        </nav>
      </div>
    </div>
  </div>
</footer>

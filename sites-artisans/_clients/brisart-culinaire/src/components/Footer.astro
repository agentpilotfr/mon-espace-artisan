---
const currentYear = new Date().getFullYear();

const liens = [
  { href: '/', label: 'Accueil' },
  { href: '/le-restaurant', label: 'Le Restaurant' },
  { href: '/bar-a-huitres', label: 'Bar à Huîtres' },
  { href: '/cours-de-cuisine', label: 'Cours de Cuisine' },
  { href: '/seminaires', label: 'Séminaires' },
  { href: '/evjf', label: 'EVJF' },
  { href: '/cocktail-dinatoire', label: 'Cocktail dînatoire' },
  { href: '/chef-a-domicile', label: 'Chef à Domicile' },
];

const legal = [
  { href: '/mentions-legales', label: 'Mentions légales' },
  { href: '/cgv', label: 'CGV' },
  { href: '/confidentialite', label: 'Confidentialité' },
];
---

<footer class="site-footer" role="contentinfo">

  <!-- Bande supérieure -->
  <div class="footer-top">
    <div class="container">
      <div class="footer-grid">

        <!-- Brand -->
        <div class="footer-brand">
          <div class="footer-logo-group">
            <a href="/" aria-label="Bris'Art Culinaire — Accueil">
              <img
                src="/images/logos/full_logo_white.svg"
                alt="Bris'Art Culinaire"
                class="footer-logo"
                loading="lazy"
              />
            </a>
            <div class="bib-distinction-card bib-distinction-card--footer" aria-label="Bib Gourmand Michelin 2026">
              <div class="bib-distinction-card__shine" aria-hidden="true"></div>
              <img
                src="/images/guillaume/distinctions/bib.png"
                alt="Bib Gourmand Michelin 2026"
                class="bib-distinction-card__img"
                loading="lazy"
                width="46"
                height="46"
              />
            </div>
          </div>

          <p class="footer-tagline">
            Restaurant gastronomique et atelier culinaire à La Baule&#8209;Escoublac.
            Chef Guillaume Brisard, anciennement étoilé au Fort de l'Océan.
          </p>

          <address class="footer-address">
            <div>39, Avenue Louis Lajarrige</div>
            <div>44500 La Baule-Escoublac</div>
            <div style="margin-top:0.5rem;">
              02 85 95 94 57
            </div>
            <div>
              <a href="mailto:contact@brisartculinaire.fr" class="footer-link">
                contact@brisartculinaire.fr
              </a>
            </div>
          </address>
        </div>

        <!-- Navigation -->
        <div class="footer-nav-col">
          <h4 class="footer-col-title">Navigation</h4>
          <nav aria-label="Footer navigation">
            <ul class="footer-links-list">
              {liens.map(l => (
                <li><a href={l.href} class="footer-link">{l.label}</a></li>
              ))}
            </ul>
          </nav>
        </div>

        <!-- Horaires -->
        <div class="footer-nav-col">
          <h4 class="footer-col-title">Horaires</h4>
          <dl class="footer-horaires">
            <div class="horaire-row">
              <dt>Lun & Mar</dt>
              <dd style="color:var(--stone-light);">Fermé</dd>
            </div>
            <div class="horaire-row">
              <dt>Mer — Sam</dt>
              <dd>10h – 16h<br><small>(déjeuner)</small></dd>
            </div>
            <div class="horaire-row">
              <dt>Mer & Ven soir</dt>
              <dd>Sur réservation<br><small>(dîner gastronomique)</small></dd>
            </div>
            <div class="horaire-row">
              <dt>Dimanche</dt>
              <dd>11h – 16h<br><small>(Bar à Huîtres)</small></dd>
            </div>
          </dl>

          <div style="margin-top:1.5rem;">
            <h4 class="footer-col-title" style="margin-bottom:0.8rem;">Réseaux</h4>
            <div class="footer-social">
              <a href="https://www.instagram.com/brisartculinaire" class="social-link" aria-label="Instagram Bris'Art Culinaire" rel="noopener noreferrer" target="_blank">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round">
                  <rect x="2" y="2" width="14" height="14" rx="4"/>
                  <circle cx="9" cy="9" r="3.5"/>
                  <circle cx="13.2" cy="4.8" r="0.8" fill="currentColor" stroke="none"/>
                </svg>
                Instagram
              </a>
              <a href="https://www.facebook.com/brisartculinaire" class="social-link" aria-label="Facebook Bris'Art Culinaire" rel="noopener noreferrer" target="_blank">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round">
                  <path d="M12 2 L10 2 C8 2 7 3 7 5 L7 7 L5 7 L5 10 L7 10 L7 16 L10 16 L10 10 L12 10 L12.5 7 L10 7 L10 5.5 C10 5 10.5 5 11 5 L12 5 Z"/>
                </svg>
                Facebook
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- Bande inférieure — légal -->
  <div class="footer-bottom">
    <div class="container">
      <div class="footer-bottom-inner">
        <p class="footer-copyright">
          © {currentYear} Bris'Art Culinaire — Guillaume Brisard. Tous droits réservés.
        </p>
        <nav class="footer-legal-links" aria-label="Liens légaux">
          {legal.map((l, i) => (
            <>
              {i > 0 && <span class="footer-sep" aria-hidden="true">·</span>}
              <a href={l.href} class="footer-legal-link">{l.label}</a>
            </>
          ))}
        </nav>
        <p class="footer-mea">
          Site créé par
          <a href="https://mon-espace-artisan.fr" class="footer-mea-link" rel="noopener">Mon Espace Artisan</a>
        </p>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--ink-deep);
    color: rgba(245,240,232,0.5);
  }

  /* Top */
  .footer-top { padding: clamp(3.5rem, 6vw, 5.5rem) 0; }
  .footer-grid {
    display: grid;
    gap: 3rem;
  }
  @media (min-width: 680px)  { .footer-grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1024px) { .footer-grid { grid-template-columns: 2fr 1fr 1fr; } }

  /* Brand */
  .footer-logo-group {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 1.5rem;
  }
  .footer-logo {
    width: 160px;
    height: auto;
    display: block;
    opacity: 0.92;
    transition: opacity 0.2s;
  }
  .footer-logo:hover { opacity: 0.7; }

  /* ─── Bib Distinction Card — logo seul, carré arrondi rouge Michelin ─── */
  .bib-distinction-card {
    position: relative;
    border-radius: 14px;
    background: linear-gradient(145deg, #b30000 0%, #CC0000 55%, #990000 100%);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    cursor: default;
    animation: bibDistinctionGlow 5s ease-in-out infinite;
  }
  .bib-distinction-card--footer {
    width: 68px;
    height: 68px;
  }
  .bib-distinction-card__shine {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(
      135deg,
      transparent 25%,
      rgba(255, 255, 255, 0.18) 50%,
      transparent 75%
    );
    background-size: 200% 200%;
    animation: bibDistinctionShimmer 4s ease-in-out infinite;
    pointer-events: none;
  }
  .bib-distinction-card__img {
    position: relative;
    z-index: 1;
    object-fit: contain;
    filter: brightness(0) invert(1);
  }
  .bib-distinction-card--footer .bib-distinction-card__img {
    width: 46px;
    height: 46px;
  }
  @keyframes bibDistinctionGlow {
    0%, 100% { box-shadow: 0 0 0 rgba(204, 0, 0, 0); }
    50%       { box-shadow: 0 4px 20px rgba(204, 0, 0, 0.55),
                            0 2px 8px  rgba(204, 0, 0, 0.30); }
  }
  @keyframes bibDistinctionShimmer {
    0%   { background-position: -200% -200%; }
    60%  { background-position: 200% 200%; }
    100% { background-position: 200% 200%; }
  }

  .footer-tagline {
    font-size: 0.85rem;
    line-height: 1.7;
    color: rgba(245,240,232,0.4);
    margin-bottom: 1.5rem;
    max-width: 300px;
  }
  .footer-address {
    font-style: normal;
    font-size: 0.82rem;
    line-height: 1.9;
    color: rgba(245,240,232,0.4);
  }

  /* Columns */
  .footer-col-title {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold-mat);
    font-weight: 400;
    font-style: normal;
    margin-bottom: 1.25rem;
  }
  .footer-links-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .footer-link {
    color: rgba(245,240,232,0.5);
    font-size: 0.875rem;
    transition: color 0.2s;
  }
  .footer-link:hover { color: var(--gold-base); }

  /* Horaires */
  .footer-horaires {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    margin: 0;
  }
  .horaire-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .horaire-row dt {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    color: rgba(245,240,232,0.4);
    align-self: start;
  }
  .horaire-row dd {
    font-size: 0.82rem;
    color: var(--gold-base);
    margin: 0;
    line-height: 1.4;
  }
  .horaire-row dd small {
    display: block;
    font-size: 0.66rem;
    color: rgba(245,240,232,0.3);
    margin-top: 0.1rem;
  }

  /* Social */
  .footer-social { display: flex; flex-direction: column; gap: 0.6rem; }
  .social-link {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.82rem;
    color: rgba(245,240,232,0.45);
    transition: color 0.2s;
  }
  .social-link:hover { color: var(--gold-base); }

  /* Bottom */
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 1.5rem 0;
  }
  .footer-bottom-inner {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 2rem;
    align-items: center;
    justify-content: space-between;
  }
  .footer-copyright {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.06em;
    color: rgba(245,240,232,0.25);
  }
  .footer-legal-links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .footer-legal-link {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.06em;
    color: rgba(245,240,232,0.25);
    transition: color 0.2s;
  }
  .footer-legal-link:hover { color: var(--gold-base); }
  .footer-sep { color: rgba(245,240,232,0.15); }

  .footer-mea {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.06em;
    color: rgba(245,240,232,0.18);
  }
  .footer-mea-link { color: rgba(201,164,74,0.45); transition: color 0.2s; }
  .footer-mea-link:hover { color: var(--gold-base); }
</style>

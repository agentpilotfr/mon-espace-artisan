---

<section id="services" class="section bg-cream">
  <div class="container">

    <div class="services-header" data-reveal>
      <span class="section-label">Nos Prestations</span>
      <div class="gold-rule" style="margin:0.9rem 0;"></div>
      <h2>Ce que nous <em style="color:var(--gold-base);">proposons</em></h2>
      <p class="services-intro">
        Du déjeuner du marché au dîner gastronomique, des cours en duo à l'immersion journée :
        chaque prestation est pensée pour transmettre la passion de Guillaume Brisard.
      </p>
    </div>

    <div class="services-rail-wrap" style="margin-top:3rem;">
      <div class="services-rail">
        {services.map((s) => (
          <article class="service-card card card-hover" style="position:relative;">
            {s.featured && <div class="featured-badge">Signature</div>}
            <div class="service-card-inner">
              <div class="service-icon" set:html={s.icon} />
              <span class="section-label" style="margin-top:1.2rem; margin-bottom:0.4rem;">{s.label}</span>
              <h3 class="service-title">{s.title}</h3>
              <p class="service-description">{s.description}</p>
              <div class="service-footer">
                <span class="service-detail">
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.2" style="display:inline; vertical-align:middle; margin-right:0.35rem; margin-top:-1px; color:var(--gold-mat);" aria-hidden="true">
                    <circle cx="6" cy="6" r="5"/><line x1="6" y1="3" x2="6" y2="6.5"/><line x1="6" y1="6.5" x2="8" y2="8"/>
                  </svg>
                  {s.detail}
                </span>
                <div class="service-price-wrap">
                  <span class="service-price">{s.price}</span>
                  <span class="service-price-unit">{s.unit}</span>
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>

    <div class="services-cta" data-reveal>
      <p class="font-accent" style="font-size:1.3rem; color:var(--stone-light); margin-bottom:1.5rem;">
        Vous ne savez pas par où commencer ?
      </p>
      <a href="tel:+33285959457" class="btn-ghost-gold">Appeler Guillaume — 02 85 95 94 57</a>
    </div>
  </div>
</section>

<style>
  .services-header { max-width: 560px; }
  .services-intro { font-size: 1rem; color: var(--stone-light); max-width: 480px; margin-top: 1rem; line-height: 1.75; }

  .service-card-inner { padding: 2rem; display: flex; flex-direction: column; height: 100%; }
  .service-icon {
    width: 48px; height: 48px;
    background: var(--parchment-bg);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    padding: 6px;
  }
  .service-title { font-size: 1.35rem; color: var(--ink); margin-bottom: 0.75rem; font-weight: 600; }
  .service-description { font-size: 0.9rem; color: var(--stone-light); line-height: 1.7; flex: 1; margin-bottom: 1.5rem; }

  .service-footer {
    border-top: 1px solid var(--parchment-bg);
    padding-top: 1.25rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }
  .service-detail { font-family: var(--font-mono); font-size: 0.65rem; color: var(--stone-light); letter-spacing: 0.08em; line-height: 1.4; }
  .service-price-wrap { text-align: right; }
  .service-price { display: block; font-family: var(--font-display); font-style: italic; font-size: 1.6rem; color: var(--gold-base); line-height: 1; }
  .service-price-unit { display: block; font-family: var(--font-mono); font-size: 0.58rem; color: var(--stone-light); letter-spacing: 0.1em; margin-top: 0.2rem; }

  .featured-badge {
    position: absolute; top: 0; right: 0;
    background: var(--gold-base); color: var(--ink-deep);
    font-family: var(--font-mono); font-size: 0.6rem; font-weight: 700;
    letter-spacing: 0.14em; text-transform: uppercase;
    padding: 5px 13px; border-radius: 0 var(--radius-card) 0 8px;
  }
  .services-cta { text-align: center; margin-top: 4rem; padding-top: 3rem; border-top: 1px solid var(--parchment-bg); }
</style>

---
const items = [
  { src: '/images/guillaume/cuisine-caviar-dressage-pro.webp', text: 'Caviar & Dressage' },
  { src: '/images/guillaume/cuisine-canapes-colores.webp',     text: 'Amuse-bouches'     },
  { src: '/images/guillaume/action-flambage-pro.webp',         text: 'Flambage'          },
  { src: '/images/guillaume/cuisine-deux-chefs-pro.webp',      text: 'Brigade'           },
  { src: '/images/guillaume/cuisine-plaque-couleur.webp',      text: 'Dressage'          },
  { src: '/images/guillaume/cuisine-mains-huitres-nb.webp',    text: 'Huîtres'           },
  { src: '/images/guillaume/action-couteau-desserts.webp',     text: 'Pâtisserie'        },
  { src: '/images/guillaume/cuisine-casseroles.webp',          text: 'En Cuisine'        },
  { src: '/images/guillaume/cuisine-huitres-nb.webp',          text: 'Fruits de Mer'     },
  { src: '/images/guillaume/cuisine-canapes-voyage.webp',      text: 'Mise en Bouche'    },
];
---

<div id="dish-gallery" style="position:relative;width:100%;height:500px;overflow:hidden;cursor:grab;">
  <canvas id="dish-canvas" style="position:absolute;inset:0;width:100%;height:100%;"></canvas>
  <!-- Labels HTML synchronisés par JS via projection 3D→2D -->
  <div id="dish-labels" style="position:absolute;inset:0;pointer-events:none;overflow:hidden;">
    {items.map((item, i) => (
      <div class="dish-label" data-idx={i} style="position:absolute;opacity:0;transition:opacity 0.25s;transform:translateX(-50%);">
        <span class="dish-label-text">{item.text}</span>
      </div>
    ))}
  </div>
  <!-- Hint scroll -->
  <div id="dish-hint" style="position:absolute;bottom:12px;left:50%;transform:translateX(-50%);opacity:0.45;pointer-events:none;display:flex;align-items:center;gap:0.4rem;">
    <svg width="18" height="10" viewBox="0 0 18 10" fill="none" stroke="#C9A44A" stroke-width="1.2" stroke-linecap="round">
      <path d="M1 5 L8 5 M8 2 L11 5 L8 8"/>
      <path d="M10 5 L17 5"/>
    </svg>
    <span style="font-family:'DM Mono',monospace;font-size:0.55rem;letter-spacing:0.14em;text-transform:uppercase;color:#C9A44A;">Faire défiler</span>
  </div>
</div>

<style>
  .dish-label-text {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-size: 0.88rem;
    color: #C9A44A;
    letter-spacing: 0.08em;
    white-space: nowrap;
    text-shadow: 0 1px 4px rgba(0,0,0,0.12);
  }
</style>

<script>
// @ts-nocheck
import {
  Renderer, Camera, Transform, Plane, Mesh, Program, Texture
} from 'ogl';

(function initDishGallery() {
  const container = document.getElementById('dish-gallery');
  const canvas    = document.getElementById('dish-canvas');
  const labelsEl  = document.getElementById('dish-labels');
  if (!container || !canvas || !labelsEl) return;

  /* ── Config ── */
  const BEND        = 2;
  const BORDER_R    = 0.08;
  const EASE        = 0.04;
  const ITEM_W      = 3.0;
  const ITEM_H      = 2.0;
  const ITEM_GAP    = 0.45;
  const STRIDE      = ITEM_W + ITEM_GAP;
  const FOV         = 35;
  const CAM_Z       = 10;
  const PX_PER_UNIT = 90;

  const itemsData = [
    { src: '/images/guillaume/cuisine-caviar-dressage-pro.webp', text: 'Caviar & Dressage' },
    { src: '/images/guillaume/cuisine-canapes-colores.webp',     text: 'Amuse-bouches'     },
    { src: '/images/guillaume/action-flambage-pro.webp',         text: 'Flambage'          },
    { src: '/images/guillaume/cuisine-deux-chefs-pro.webp',      text: 'Brigade'           },
    { src: '/images/guillaume/cuisine-plaque-couleur.webp',      text: 'Dressage'          },
    { src: '/images/guillaume/cuisine-mains-huitres-nb.webp',    text: 'Huîtres'           },
    { src: '/images/guillaume/action-couteau-desserts.webp',     text: 'Pâtisserie'        },
    { src: '/images/guillaume/cuisine-casseroles.webp',          text: 'En Cuisine'        },
    { src: '/images/guillaume/cuisine-huitres-nb.webp',          text: 'Fruits de Mer'     },
    { src: '/images/guillaume/cuisine-canapes-voyage.webp',      text: 'Mise en Bouche'    },
  ];

  /* ── Renderer ── */
  const renderer = new Renderer({
    canvas,
    alpha: true,
    dpr: Math.min(window.devicePixelRatio, 2),
  });
  const gl = renderer.gl;
  gl.clearColor(0, 0, 0, 0);

  const camera = new Camera(gl, { fov: FOV });
  camera.position.z = CAM_Z;
  const scene = new Transform();

  /* ── Shaders ── */
  const vertex = /* glsl */`
    attribute vec3 position;
    attribute vec2 uv;
    uniform mat4 modelViewMatrix;
    uniform mat4 projectionMatrix;
    uniform float uBend;
    uniform float uWorldX;
    varying vec2 vUv;
    void main() {
      vUv = uv;
      vec3 pos = position;
      float wx = pos.x + uWorldX;
      pos.y -= wx * wx * uBend * 0.011;
      gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
    }
  `;

  const fragment = /* glsl */`
    precision highp float;
    uniform sampler2D tMap;
    uniform float uRadius;
    varying vec2 vUv;
    float sdRoundRect(vec2 p, float r) {
      vec2 q = abs(p * 2.0 - 1.0) - 1.0 + r;
      return length(max(q, 0.0)) - r;
    }
    void main() {
      float d = sdRoundRect(vUv, uRadius);
      float a = 1.0 - smoothstep(-0.01, 0.015, d);
      if (a < 0.01) discard;
      vec4 col = texture2D(tMap, vUv);
      gl_FragColor = vec4(col.rgb, col.a * a);
    }
  `;

  /* ── Meshes ── */
  const geometry = new Plane(gl, {
    width: ITEM_W, height: ITEM_H,
    widthSegments: 30, heightSegments: 1,
  });

  const meshes = [];
  const labelEls = Array.from(labelsEl.querySelectorAll('.dish-label'));

  itemsData.forEach((item, i) => {
    const texture = new Texture(gl, { generateMipmaps: false });
    const img = new Image();
    img.onload = () => { texture.image = img; };
    img.src = item.src;

    const program = new Program(gl, {
      vertex, fragment,
      uniforms: {
        tMap:    { value: texture },
        uBend:   { value: BEND },
        uWorldX: { value: 0 },
        uRadius: { value: BORDER_R },
      },
      transparent: true,
      cullFace: null,
    });

    const mesh = new Mesh(gl, { geometry, program });
    mesh.position.x = i * STRIDE;
    mesh.setParent(scene);
    meshes.push(mesh);
  });

  /* Center */
  const totalW = itemsData.length * STRIDE - ITEM_GAP;
  meshes.forEach(m => { m.position.x -= totalW / 2; });

  /* ── Scroll / Drag ── */
  let scrollPx = 0, targetPx = 0;
  const maxPx = (itemsData.length - 1) * STRIDE * PX_PER_UNIT;

  let dragging = false, dragStartX = 0, dragBase = 0;

  container.addEventListener('wheel', e => {
    e.preventDefault();
    targetPx = Math.max(0, Math.min(maxPx, targetPx + (e.deltaX || e.deltaY) * 0.9));
  }, { passive: false });

  container.addEventListener('mousedown', e => {
    dragging = true; dragStartX = e.clientX; dragBase = targetPx;
    container.style.cursor = 'grabbing';
  });
  window.addEventListener('mouseup', () => {
    dragging = false;
    container.style.cursor = 'grab';
  });
  window.addEventListener('mousemove', e => {
    if (!dragging) return;
    targetPx = Math.max(0, Math.min(maxPx, dragBase + (dragStartX - e.clientX) * 2.2));
  });

  let touchX = 0, touchBase = 0;
  container.addEventListener('touchstart', e => {
    touchX = e.touches[0].clientX; touchBase = targetPx;
  }, { passive: true });
  container.addEventListener('touchmove', e => {
    targetPx = Math.max(0, Math.min(maxPx, touchBase + (touchX - e.touches[0].clientX) * 2.2));
  }, { passive: true });

  /* ── Resize ── */
  function resize() {
    renderer.setSize(container.clientWidth, container.clientHeight);
    camera.perspective({ aspect: container.clientWidth / container.clientHeight });
  }
  window.addEventListener('resize', resize, { passive: true });
  resize();

  /* ── Projection helper ── */
  function worldToScreen(wx, wy) {
    const W = container.clientWidth;
    const H = container.clientHeight;
    const halfH = Math.tan((FOV * Math.PI) / 360) * CAM_Z;
    const halfW = halfH * (W / H);
    return {
      x:  ((wx / halfW) * 0.5 + 0.5) * W,
      y: ((-wy / halfH) * 0.5 + 0.5) * H,
    };
  }

  /* ── Hint fade ── */
  const hint = document.getElementById('dish-hint');
  let hintFaded = false;

  /* ── RAF loop ── */
  function tick() {
    requestAnimationFrame(tick);
    scrollPx += (targetPx - scrollPx) * EASE;
    const offsetW = scrollPx / PX_PER_UNIT;

    meshes.forEach((mesh, i) => {
      const baseX = i * STRIDE - totalW / 2;
      const x = baseX - offsetW;
      mesh.position.x = x;
      mesh.program.uniforms.uWorldX.value = x;

      const label = labelEls[i];
      if (label) {
        const s = worldToScreen(x, mesh.position.y - ITEM_H / 2 - 0.22);
        label.style.left = `${s.x}px`;
        label.style.top  = `${s.y}px`;
        const visible = s.x > -120 && s.x < container.clientWidth + 120;
        label.style.opacity = visible ? '1' : '0';
      }
    });

    renderer.render({ scene, camera });

    if (!hintFaded && Math.abs(targetPx) > 20) {
      hintFaded = true;
      if (hint) hint.style.opacity = '0';
    }
  }
  tick();
})();
</script>

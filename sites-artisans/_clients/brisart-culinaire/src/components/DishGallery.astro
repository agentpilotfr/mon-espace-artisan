---
const dishes = [
  { src: '/images/guillaume/cuisine_plat/photo-7.webp',               label: 'Gastronomie'  },
  { src: '/images/guillaume/cuisine_plat/photo-6.webp',               label: 'Dressage'     },
  { src: '/images/guillaume/cuisine_plat/photo-4.webp',               label: 'Précision'    },
  { src: '/images/guillaume/cuisine_plat/photo-3.webp',               label: 'Saison'       },
  { src: '/images/guillaume/cuisine_plat/langoustine-croisic.webp',   label: 'Langoustine'  },
  { src: '/images/guillaume/cuisine_plat/coursdecuisinelabaule.webp', label: 'La Baule'     },
  { src: '/images/guillaume/cuisine_plat/8.webp',                     label: 'Création'     },
  { src: '/images/guillaume/cuisine_plat/photo-7.webp',               label: 'Gastronomie'  },
  { src: '/images/guillaume/cuisine_plat/photo-6.webp',               label: 'Dressage'     },
  { src: '/images/guillaume/cuisine_plat/photo-4.webp',               label: 'Précision'    },
  { src: '/images/guillaume/cuisine_plat/photo-3.webp',               label: 'Saison'       },
  { src: '/images/guillaume/cuisine_plat/langoustine-croisic.webp',   label: 'Langoustine'  },
];
---

<section class="dish-gallery-section">
  <div class="dish-gallery-track" id="dish-track">
    {dishes.map((dish) => (
      <div class="dish-card" data-tilt>
        <div class="dish-card-inner">
          <img
            src={dish.src}
            alt={`Gastronomie Bris'Art — ${dish.label}`}
            loading="lazy"
          />
          <div class="dish-card-shine"></div>
          <div class="dish-card-label">{dish.label}</div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .dish-gallery-section {
    width: 100%;
    overflow: hidden;
    padding: 0 0 2rem;
    background: transparent;
  }

  .dish-gallery-track {
    display: flex;
    gap: 1.25rem;
    padding: 1rem 2rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    cursor: grab;
  }
  .dish-gallery-track::-webkit-scrollbar { display: none; }
  .dish-gallery-track:active { cursor: grabbing; }

  .dish-card {
    flex-shrink: 0;
    width: clamp(260px, 28vw, 380px);
    height: clamp(300px, 32vw, 440px);
    scroll-snap-align: start;
    transform-style: preserve-3d;
    perspective: 1000px;
  }

  .dish-card-inner {
    width: 100%;
    height: 100%;
    border-radius: 6px;
    overflow: hidden;
    position: relative;
    transition: transform 0.15s ease;
    transform-style: preserve-3d;
    box-shadow: 0 8px 32px rgba(26,25,22,0.12);
  }

  .dish-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .dish-card-shine {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at var(--mx, 50%) var(--my, 50%),
      rgba(201,164,74,0.18) 0%,
      transparent 60%
    );
    opacity: 0;
    transition: opacity 0.3s;
    pointer-events: none;
    z-index: 2;
  }

  .dish-card:hover .dish-card-shine { opacity: 1; }
  .dish-card:hover img { transform: scale(1.04); }

  .dish-card-label {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--cream);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0;
    transform: translateY(6px);
    transition: all 0.3s;
    z-index: 3;
  }

  .dish-card:hover .dish-card-label {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
// @ts-nocheck
(function () {
  /* ── Tilt 3D hover ── */
  document.querySelectorAll('[data-tilt]').forEach(card => {
    const inner = card.querySelector('.dish-card-inner');
    const shine = card.querySelector('.dish-card-shine');
    if (!inner || !shine) return;

    card.addEventListener('mousemove', e => {
      const r = card.getBoundingClientRect();
      const x = (e.clientX - r.left) / r.width;
      const y = (e.clientY - r.top) / r.height;
      const rx = (y - 0.5) * -16;
      const ry = (x - 0.5) * 16;
      inner.style.transform = `rotateX(${rx}deg) rotateY(${ry}deg) scale(1.02)`;
      shine.style.setProperty('--mx', x * 100 + '%');
      shine.style.setProperty('--my', y * 100 + '%');
    });

    card.addEventListener('mouseleave', () => {
      inner.style.transform = '';
    });
  });

  /* ── Drag scroll ── */
  const track = document.getElementById('dish-track');
  if (!track) return;

  let isDown = false, startX = 0, scrollLeft = 0;

  track.addEventListener('mousedown', e => {
    isDown = true;
    startX = e.pageX - track.offsetLeft;
    scrollLeft = track.scrollLeft;
  });
  track.addEventListener('mouseleave', () => { isDown = false; });
  track.addEventListener('mouseup',    () => { isDown = false; });
  track.addEventListener('mousemove', e => {
    if (!isDown) return;
    e.preventDefault();
    const x = e.pageX - track.offsetLeft;
    track.scrollLeft = scrollLeft - (x - startX) * 1.5;
  });
})();
</script>

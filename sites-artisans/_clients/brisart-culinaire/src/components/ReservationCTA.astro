---
// Section CTA Réservation — données réelles Bris'Art Culinaire
---

<section id="reservation" class="reservation-section">
  <!-- Fond botanique décoratif -->
  <div class="reservation-bg" aria-hidden="true">
    <svg class="res-botanical" viewBox="0 0 400 300" fill="none" preserveAspectRatio="xMidYMid slice">
      <path d="M200 300 C198 240 202 180 200 120 C198 60 200 20 200 0" stroke="#C9A44A" stroke-width="1.8" stroke-linecap="round"/>
      <path d="M200 270 C178 252 155 241 130 233" stroke="#C9A44A" stroke-width="1.2" stroke-linecap="round" fill="none"/>
      <path d="M200 270 C224 252 247 242 272 234" stroke="#C9A44A" stroke-width="1.2" stroke-linecap="round" fill="none"/>
      <path d="M200 240 C176 220 150 209 122 201" stroke="#C9A44A" stroke-width="1.1" stroke-linecap="round" fill="none"/>
      <path d="M200 240 C226 220 252 210 280 202" stroke="#C9A44A" stroke-width="1.1" stroke-linecap="round" fill="none"/>
      <path d="M200 210 C174 188 146 177 118 169" stroke="#C9A44A" stroke-width="1" stroke-linecap="round" fill="none"/>
      <path d="M200 210 C228 188 256 178 284 170" stroke="#C9A44A" stroke-width="1" stroke-linecap="round" fill="none"/>
      <path d="M200 180 C172 158 142 146 112 138" stroke="#C9A44A" stroke-width="0.9" stroke-linecap="round" fill="none"/>
      <path d="M200 180 C230 158 260 147 290 139" stroke="#C9A44A" stroke-width="0.9" stroke-linecap="round" fill="none"/>
      <ellipse cx="200" cy="14" rx="8" ry="12" stroke="#C9A44A" stroke-width="0.9"/>
      <ellipse cx="188" cy="22" rx="5.5" ry="9" stroke="#C9A44A" stroke-width="0.8"/>
      <ellipse cx="212" cy="20" rx="5.5" ry="9" stroke="#C9A44A" stroke-width="0.8"/>
    </svg>
  </div>

  <div class="container" style="position:relative; z-index:1;">
    <div class="reservation-inner">

      <!-- Header -->
      <div class="reservation-header" data-reveal>
        <span class="section-label" style="text-align:center; display:block;">Réservation</span>
        <div class="gold-rule gold-rule-center" style="margin:1.1rem auto;"></div>
        <h2 style="color:var(--parchment); text-align:center; max-width:580px; margin:0 auto 1.2rem;">
          Réservez votre<br>
          <em style="color:var(--gold-base);">table ou cours</em>
        </h2>
        <p style="color:var(--stone-light); text-align:center; max-width:460px; margin:0 auto 3rem; font-size:0.95rem; line-height:1.75;">
          Pour le restaurant, réservez en ligne.
          Guillaume vous répond personnellement pour les cours et événements.
        </p>
      </div>

      <!-- CTA réservation restaurant (laddition) -->
      <div class="reservation-online" data-reveal>
        <a
          href="https://reservation.laddition.com/booking/brisartculinaire"
          class="btn-gold btn-resa-online"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" aria-hidden="true">
            <rect x="2" y="3" width="14" height="13" rx="2" stroke-width="1.2"/>
            <line x1="2" y1="7" x2="16" y2="7"/>
            <line x1="6" y1="1" x2="6" y2="5"/>
            <line x1="12" y1="1" x2="12" y2="5"/>
            <path d="M6 11 L7.5 12.5 L12 9"/>
          </svg>
          Réserver une table en ligne
        </a>
        <p class="resa-online-note">
          Réservation en ligne disponible 24h/24 via notre partenaire L'Addition
        </p>
      </div>

      <!-- Divider -->
      <div class="resa-divider" data-reveal>
        <div class="resa-divider-line"></div>
        <span class="section-label">Ou par email</span>
        <div class="resa-divider-line"></div>
      </div>

      <!-- Formulaire cours / événements -->
      <form class="reservation-form" data-reveal action="#" method="POST" novalidate>
        <p class="form-intro">Pour les <strong>cours de cuisine</strong>, <strong>séminaires</strong>, <strong>EVJF</strong> ou tout <strong>événement privatif</strong> :</p>

        <div class="form-row">
          <div class="form-group">
            <label for="prenom">Prénom</label>
            <input type="text" id="prenom" name="prenom" placeholder="Marie" required autocomplete="given-name"/>
          </div>
          <div class="form-group">
            <label for="nom">Nom</label>
            <input type="text" id="nom" name="nom" placeholder="Dupont" required autocomplete="family-name"/>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="marie@exemple.fr" required autocomplete="email"/>
          </div>
          <div class="form-group">
            <label for="telephone">Téléphone</label>
            <input type="tel" id="telephone" name="telephone" placeholder="06 XX XX XX XX" autocomplete="tel"/>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="prestation">Prestation souhaitée</label>
            <select id="prestation" name="prestation" required>
              <option value="" disabled selected>Choisir…</option>
              <optgroup label="Restaurant">
                <option value="dejeuner">Déjeuner — Menu du marché (35 €)</option>
                <option value="table-chef">Table du Chef — Dîner gastronomique 6 services (125 €)</option>
                <option value="bar-huitres">Bar à Huîtres</option>
              </optgroup>
              <optgroup label="Cours de cuisine">
                <option value="cours-1">Cours n°1 — 2h au restaurant (95 €)</option>
                <option value="cours-2">Cours n°2 — 2h + dégustation (125 €)</option>
                <option value="cours-3">Cours n°3 Coup de cœur — Marché + cours + déjeuner (155 €)</option>
                <option value="immersion">Atelier Immersion journée chef (299 €)</option>
              </optgroup>
              <optgroup label="Événements">
                <option value="seminaire">Séminaire / Team Building — 125 €</option>
                <option value="evjf">EVJF / EVG</option>
                <option value="cocktail">Cocktail dînatoire</option>
                <option value="chef-domicile">Chef à domicile</option>
                <option value="prive">Événement privatif — devis</option>
              </optgroup>
            </select>
          </div>
          <div class="form-group">
            <label for="date">Date souhaitée</label>
            <input type="date" id="date" name="date"/>
          </div>
        </div>

        <div class="form-group">
          <label for="message">Message (optionnel)</label>
          <textarea id="message" name="message" rows="3" placeholder="Nombre de personnes, contraintes alimentaires, ou toute autre demande particulière…"></textarea>
        </div>

        <div class="form-submit">
          <button type="submit" class="btn-gold" style="width:100%; justify-content:center; display:flex; align-items:center; gap:0.6rem;">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M2 8 L14 8 M10 4 L14 8 L10 12"/>
            </svg>
            Envoyer ma demande
          </button>
          <p class="form-legal">
            En soumettant ce formulaire, vous acceptez notre
            <a href="/mentions-legales" style="color:var(--gold-mat); text-decoration:underline;">politique de confidentialité</a>.
          </p>
        </div>
      </form>

      <!-- Contact direct -->
      <div class="contact-direct" data-reveal>
        <div class="contact-links">
          <a href="mailto:contact@brisartculinaire.fr" class="contact-item">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="#C9A44A" stroke-width="1.2" stroke-linecap="round" aria-hidden="true">
              <rect x="2" y="4" width="14" height="10" rx="2" stroke-width="1.1"/>
              <path d="M2 6 L9 11 L16 6"/>
            </svg>
            contact@brisartculinaire.fr
          </a>
          <div class="contact-item" style="cursor:default;">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="#C9A44A" stroke-width="1.2" stroke-linecap="round" aria-hidden="true">
              <circle cx="9" cy="7.5" r="3.5"/>
              <path d="M9 14 C9 14 3 9.5 3 7.5 C3 4 5.8 2 9 2 C12.2 2 15 4 15 7.5 C15 9.5 9 14 9 14Z"/>
            </svg>
            39, Av. Louis Lajarrige — 44500 La Baule
          </div>
        </div>

        <div class="horaires">
          <span class="section-label" style="margin-bottom:0.75rem;">Horaires</span>
          <div class="horaires-grid">
            <span>Lundi & Mardi</span>
            <span style="color:var(--stone-light);">Fermé</span>
            <span>Mercredi — Samedi</span>
            <span style="color:var(--gold-base);">10h – 16h</span>
            <span>Mer & Ven soir</span>
            <span style="color:var(--gold-base);">Sur réservation</span>
            <span>Dimanche</span>
            <span style="color:var(--gold-base);">11h – 16h (Bar à Huîtres)</span>
          </div>
          <p class="horaires-note">Dîner gastronomique 6 services uniquement sur réservation par email.</p>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .reservation-section {
    background: var(--ink);
    position: relative;
    overflow: hidden;
    padding: clamp(5rem, 9vw, 9rem) 0;
  }
  .reservation-bg {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    pointer-events: none;
    opacity: 0.05;
  }
  .res-botanical { width: 50%; max-width: 400px; height: 100%; }

  .reservation-inner { max-width: 720px; margin: 0 auto; }

  /* Bouton réservation en ligne */
  .reservation-online {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .btn-resa-online {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    font-size: 0.9rem;
    padding: 18px 48px;
  }
  .resa-online-note {
    font-family: var(--font-mono);
    font-size: 0.63rem;
    letter-spacing: 0.1em;
    color: rgba(245,240,232,0.25);
    margin-top: 0.85rem;
    text-transform: uppercase;
  }

  /* Divider */
  .resa-divider {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }
  .resa-divider-line {
    flex: 1;
    height: 1px;
    background: rgba(201,164,74,0.12);
  }

  /* Form */
  .form-intro {
    font-size: 0.88rem;
    color: rgba(245,240,232,0.5);
    margin-bottom: 1.5rem;
    line-height: 1.65;
  }
  .form-intro strong { color: rgba(245,240,232,0.75); font-weight: 500; }

  .reservation-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 2.5rem;
    background: rgba(245,240,232,0.04);
    border: 1px solid rgba(201,164,74,0.15);
    border-radius: var(--radius-card);
    margin-bottom: 3rem;
  }
  .form-row { display: grid; gap: 1.25rem; }
  @media (min-width: 560px) { .form-row { grid-template-columns: 1fr 1fr; } }
  .form-group { display: flex; flex-direction: column; }

  .form-submit { margin-top: 0.5rem; }
  .form-legal {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: rgba(245,240,232,0.25);
    text-align: center;
    margin-top: 1rem;
    line-height: 1.6;
    letter-spacing: 0.04em;
  }

  /* Contact direct */
  .contact-direct {
    padding-top: 2.5rem;
    border-top: 1px solid rgba(201,164,74,0.12);
    display: grid;
    gap: 2rem;
  }
  @media (min-width: 640px) { .contact-direct { grid-template-columns: 1fr 1fr; } }

  .contact-links { display: flex; flex-direction: column; gap: 1rem; }
  .contact-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-body);
    font-size: 0.88rem;
    color: rgba(245,240,232,0.65);
    transition: color 0.2s;
  }
  a.contact-item:hover { color: var(--gold-base); }

  .horaires-grid {
    display: grid;
    grid-template-columns: auto auto;
    gap: 0.5rem 1.5rem;
    font-size: 0.84rem;
    color: rgba(245,240,232,0.5);
  }
  .horaires-note {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.05em;
    color: rgba(245,240,232,0.25);
    margin-top: 1rem;
    line-height: 1.6;
  }
</style>

---
interface Props {
  transparent?: boolean;
}
const { transparent = false } = Astro.props;
---

<header id="site-header" class:list={['w-full px-6 md:px-10', { 'is-scrolled': !transparent }]}>
  <div class="flex items-center justify-between h-16 md:h-20 max-w-[1320px] mx-auto">

    <!-- Logo — lettrage blanc sur fond sombre (transparent ou noir encre) -->
    <a href="/" class="logo-link" aria-label="Bris'Art Culinaire — Accueil">
      <img
        src="/images/logos/logo_lettrage.svg"
        alt="Bris'Art Culinaire"
        width="150"
        height="40"
        class="logo-img"
        loading="eager"
      />
    </a>

    <!-- Desktop Nav (≥ 1024px) -->
    <nav class="hidden lg:flex items-center gap-8" aria-label="Navigation principale">
      <a href="/" class="nav-link">Accueil</a>
      <a href="/le-restaurant" class="nav-link">Le Restaurant</a>

      <!-- Dropdown Prestations -->
      <div class="prestations-wrap">
        <button
          id="prestations-btn"
          class="nav-link prestations-btn-inner"
          aria-expanded="false"
          aria-haspopup="true"
        >
          Prestations
          <svg class="prest-chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
            <path d="M2 3.5 L5 6.5 L8 3.5"/>
          </svg>
        </button>

        <div id="prestations-dropdown" class="prest-dropdown" aria-hidden="true">
          <a href="/cours-de-cuisine" class="prest-option">
            <span>Cours de cuisine</span>
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" aria-hidden="true"><path d="M2 6 L10 6 M7 3 L10 6 L7 9"/></svg>
          </a>
          <a href="/seminaires" class="prest-option">
            <span>Séminaires</span>
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" aria-hidden="true"><path d="M2 6 L10 6 M7 3 L10 6 L7 9"/></svg>
          </a>
          <a href="/evjf" class="prest-option">
            <span>EVJF</span>
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" aria-hidden="true"><path d="M2 6 L10 6 M7 3 L10 6 L7 9"/></svg>
          </a>
          <a href="/cocktail-dinatoire" class="prest-option">
            <span>Cocktail dînatoire</span>
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" aria-hidden="true"><path d="M2 6 L10 6 M7 3 L10 6 L7 9"/></svg>
          </a>
          <a href="/chef-a-domicile" class="prest-option">
            <span>Chef à domicile</span>
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" aria-hidden="true"><path d="M2 6 L10 6 M7 3 L10 6 L7 9"/></svg>
          </a>
        </div>
      </div>

      <!-- Bouton RÉSERVER + dropdown -->
      <div class="resa-wrap">
        <button
          id="resa-btn"
          class="btn-gold resa-btn-inner"
          aria-expanded="false"
          aria-haspopup="true"
        >
          Réserver
          <svg class="resa-chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
            <path d="M2 3.5 L5 6.5 L8 3.5"/>
          </svg>
        </button>

        <div id="resa-dropdown" class="resa-dropdown" aria-hidden="true">
          <a
            href="https://reservation.laddition.com/booking/brisartculinaire"
            target="_blank"
            rel="noopener noreferrer"
            class="resa-option resa-option-primary"
          >
            <span>Réserver une table en ligne</span>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" aria-hidden="true">
              <path d="M2 7 L12 7 M8.5 3.5 L12 7 L8.5 10.5"/>
            </svg>
          </a>

          <div class="resa-sep">
            <div class="resa-sep-line"></div>
            <span class="resa-sep-text">ou</span>
            <div class="resa-sep-line"></div>
          </div>

          <a href="/cours-de-cuisine" class="resa-option resa-option-secondary">
            <span>Réserver ou offrir un cours</span>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" aria-hidden="true">
              <path d="M2 7 L12 7 M8.5 3.5 L12 7 L8.5 10.5"/>
            </svg>
          </a>
        </div>
      </div>
    </nav>

    <!-- Hamburger (mobile < 1024px) -->
    <button
      id="hamburger-btn"
      class="hamburger lg:hidden"
      aria-label="Menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<!-- Mobile Menu Overlay -->
<nav id="mobile-menu" class="mobile-menu" aria-label="Menu mobile" aria-hidden="true">
  <button
    id="mobile-close"
    class="absolute top-5 right-6 text-parchment opacity-60 hover:opacity-100 transition-opacity"
    aria-label="Fermer le menu"
  >
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>

  <div class="text-center">
    <div class="gold-rule gold-rule-center mb-8"></div>
    <div class="flex flex-col items-center gap-6">
      <a href="/" class="nav-link text-base">Accueil</a>
      <a href="/le-restaurant" class="nav-link text-base">Le Restaurant</a>
      <div class="mob-prest-group">
        <span class="mob-prest-title">Prestations</span>
        <div class="flex flex-col items-center gap-4 mt-3">
          <a href="/cours-de-cuisine" class="nav-link text-sm">Cours de cuisine</a>
          <a href="/seminaires" class="nav-link text-sm">Séminaires</a>
          <a href="/evjf" class="nav-link text-sm">EVJF</a>
          <a href="/cocktail-dinatoire" class="nav-link text-sm">Cocktail dînatoire</a>
          <a href="/chef-a-domicile" class="nav-link text-sm">Chef à domicile</a>
        </div>
      </div>
    </div>
    <div class="gold-rule gold-rule-center mt-8 mb-8"></div>
    <a
      href="https://reservation.laddition.com/booking/brisartculinaire"
      class="btn-gold"
      target="_blank"
      rel="noopener noreferrer"
    >Réserver une table</a>
    <p class="font-mono-sm mt-6 tracking-widest text-[0.65rem] uppercase" style="color:rgba(245,240,232,0.35);">
      La Baule · Gastronomie Artisanale
    </p>
  </div>
</nav>

<script>
  /* ── Header scroll ── */
  const header = document.getElementById('site-header');
  const isHome = window.location.pathname === '/';
  let lastY = 0;
  let isScrolled = header?.classList.contains('is-scrolled') ?? false;

  window.addEventListener('scroll', () => {
    const y = window.scrollY;
    // Pages intérieures : fond noir encre permanent (jamais retiré)
    const nowScrolled = isHome ? y > 80 : true;

    if (nowScrolled !== isScrolled) {
      isScrolled = nowScrolled;
      header?.classList.toggle('is-scrolled', isScrolled);
    }

    header?.classList.toggle('is-hidden', y > lastY + 8 && y > 300);
    lastY = y;
  }, { passive: true });

  /* ── Hamburger ── */
  const btn   = document.getElementById('hamburger-btn');
  const menu  = document.getElementById('mobile-menu');
  const close = document.getElementById('mobile-close');
  const links = menu?.querySelectorAll('a');

  function openMenu() {
    btn?.classList.add('is-open');
    menu?.classList.add('is-open');
    btn?.setAttribute('aria-expanded', 'true');
    menu?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function closeMenu() {
    btn?.classList.remove('is-open');
    menu?.classList.remove('is-open');
    btn?.setAttribute('aria-expanded', 'false');
    menu?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  btn?.addEventListener('click', () => menu?.classList.contains('is-open') ? closeMenu() : openMenu());
  close?.addEventListener('click', closeMenu);
  links?.forEach(l => l.addEventListener('click', closeMenu));
  document.addEventListener('keydown', e => { if (e.key === 'Escape') { closeMenu(); closeDrop(); closePrest(); } });

  /* ── Dropdown Prestations ── */
  const prestBtn  = document.getElementById('prestations-btn');
  const prestDrop = document.getElementById('prestations-dropdown');

  function openPrest() {
    prestDrop?.classList.add('is-open');
    prestBtn?.setAttribute('aria-expanded', 'true');
    prestDrop?.setAttribute('aria-hidden', 'false');
    closeDrop();
  }
  function closePrest() {
    prestDrop?.classList.remove('is-open');
    prestBtn?.setAttribute('aria-expanded', 'false');
    prestDrop?.setAttribute('aria-hidden', 'true');
  }

  prestBtn?.addEventListener('click', e => {
    e.stopPropagation();
    prestDrop?.classList.contains('is-open') ? closePrest() : openPrest();
  });

  /* ── Dropdown Réserver ── */
  const resaBtn  = document.getElementById('resa-btn');
  const resaDrop = document.getElementById('resa-dropdown');

  function openDrop() {
    resaDrop?.classList.add('is-open');
    resaBtn?.setAttribute('aria-expanded', 'true');
    resaDrop?.setAttribute('aria-hidden', 'false');
    closePrest();
  }
  function closeDrop() {
    resaDrop?.classList.remove('is-open');
    resaBtn?.setAttribute('aria-expanded', 'false');
    resaDrop?.setAttribute('aria-hidden', 'true');
  }

  resaBtn?.addEventListener('click', e => {
    e.stopPropagation();
    resaDrop?.classList.contains('is-open') ? closeDrop() : openDrop();
  });

  document.addEventListener('click', e => {
    if (!prestBtn?.contains(e.target as Node) && !prestDrop?.contains(e.target as Node)) closePrest();
    if (!resaBtn?.contains(e.target as Node) && !resaDrop?.contains(e.target as Node)) closeDrop();
  });
</script>

<style>
  /* ── Logo ── */
  .logo-link { display: flex; align-items: center; }
  .logo-img {
    width: clamp(160px, 18vw, 220px);
    height: auto;
    max-height: 52px;
    object-fit: contain;
    display: block;
    transition: opacity 0.2s ease;
  }
  .logo-link:hover .logo-img { opacity: 0.8; }

  /* ── Prestations dropdown ── */
  .prestations-wrap { position: relative; }
  .prestations-btn-inner {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .prest-chevron {
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }
  #prestations-btn[aria-expanded="true"] .prest-chevron {
    transform: rotate(180deg);
  }

  .prest-dropdown {
    position: absolute;
    top: calc(100% + 0.6rem);
    left: 50%;
    transform: translateX(-50%) translateY(-6px);
    min-width: 220px;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 0.75rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
    z-index: 200;
    box-shadow: 0 8px 32px rgba(26,25,22,0.1);
  }
  .prest-dropdown.is-open {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  .prest-option {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.6rem 0.75rem;
    border-radius: 4px;
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-ink-secondary);
    transition: background 0.15s, color 0.15s;
    text-decoration: none;
  }
  .prest-option:hover {
    background: var(--color-bg-secondary);
    color: var(--gold-base);
  }

  /* Mobile prestations group */
  .mob-prest-group { text-align: center; }
  .mob-prest-title {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold-base);
    display: block;
  }

  /* ── Bouton Réserver ── */
  .resa-wrap { position: relative; }
  .resa-btn-inner {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.75rem;
    padding: 0.625rem 1.5rem;
  }
  .resa-chevron {
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }
  #resa-btn[aria-expanded="true"] .resa-chevron {
    transform: rotate(180deg);
  }

  /* ── Dropdown Réserver ── */
  .resa-dropdown {
    position: absolute;
    top: calc(100% + 0.6rem);
    right: 0;
    min-width: 290px;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 1.5rem;
    opacity: 0;
    pointer-events: none;
    transform: translateY(-6px);
    transition: opacity 0.2s ease, transform 0.2s ease;
    z-index: 200;
    box-shadow: 0 8px 32px rgba(26,25,22,0.1);
  }
  .resa-dropdown.is-open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .resa-option {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    text-decoration: none;
    padding: 0.2rem 0;
    transition: opacity 0.15s;
  }
  .resa-option-primary {
    font-size: 0.9rem;
    color: var(--gold-base);
  }
  .resa-option-primary:hover { color: var(--gold-mat); }

  .resa-option-secondary {
    font-size: 0.8rem;
    color: var(--color-ink-secondary);
    opacity: 0.65;
  }
  .resa-option-secondary:hover { opacity: 1; }

  .resa-sep {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 1rem 0;
  }
  .resa-sep-line {
    flex: 1;
    height: 1px;
    background: var(--color-border);
  }
  .resa-sep-text {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    color: var(--color-steel);
    text-transform: uppercase;
  }
</style>

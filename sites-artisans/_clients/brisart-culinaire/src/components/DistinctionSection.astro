---
import MichelinTiltCard from './MichelinTiltCard.astro';
---

<section class="distinction-section" data-reveal>
  <div class="distinction-inner">

    <!-- Colonne texte + tilt card -->
    <div class="distinction-left">
      <span class="section-label">Distinction 2026</span>
      <h2>Reconnu par le<br><em style="color:var(--gold-base);">Guide Michelin</em></h2>
      <p>
        Bris'Art Culinaire figure au Guide Michelin 2026,
        récompensé du Bib Gourmand pour la qualité
        exceptionnelle de sa cuisine au meilleur
        rapport qualité-prix.
      </p>
      <p>
        Obtenu en seulement 6 mois après l'ouverture du restaurant —
        une distinction qui vient saluer l'exigence et la constance
        d'une cuisine sincère, précise et généreuse.
      </p>
      <div class="distinction-ctas">
        <a href="/le-restaurant" class="btn-ghost-gold">
          Découvrir le restaurant
        </a>
        <a
          href="https://reservation.laddition.com/booking/brisartculinaire"
          class="btn-gold"
          target="_blank"
          rel="noopener noreferrer"
        >
          Réserver une table
        </a>
      </div>
      <div class="distinction-tilt-wrapper">
        <a
          href="https://actu.fr/pays-de-la-loire/la-baule-escoublac_44055/ce-restaurant-de-loire-atlantique-recompense-par-le-guide-michelin-six-mois-seulement-apres-son-ouverture_63844228.html"
          target="_blank"
          rel="noopener"
          aria-label="Lire l'article — Bib Gourmand Michelin 2026"
          style="display:inline-block; text-decoration:none;"
        >
          <MichelinTiltCard />
        </a>
      </div>
    </div>

    <!-- Photo cérémonie -->
    <div class="distinction-right">
      <div class="distinction-photo-wrapper">
        <img
          src="/images/guillaume/distinctions/michelin-ceremonie-2026.webp"
          alt="Guillaume Brisard reçoit le Bib Gourmand Guide Michelin 2026"
          class="distinction-photo"
          loading="lazy"
          width="480"
        />
        <div class="distinction-photo-caption">
          <span class="caption-label">Cérémonie Guide Michelin</span>
          <span class="caption-year">Paris · 2026</span>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .distinction-section {
    padding: 5rem 2rem;
    background: var(--color-bg-secondary);
  }
  .distinction-inner {
    max-width: 1000px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .distinction-left {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .distinction-left h2 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 2.8rem);
    font-weight: 300;
    color: var(--color-ink);
    line-height: 1.2;
  }
  .distinction-left p {
    font-size: 0.85rem;
    color: var(--color-ink-secondary);
    line-height: 1.8;
    max-width: 420px;
  }
  .distinction-ctas {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .distinction-tilt-wrapper {
    margin-top: 1.5rem;
  }
  .distinction-right {
    position: relative;
  }
  .distinction-photo-wrapper {
    position: relative;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(26,25,22,0.15);
  }
  .distinction-photo {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.6s ease;
  }
  .distinction-photo-wrapper:hover .distinction-photo {
    transform: scale(1.03);
  }
  .distinction-photo-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1rem 1.25rem;
    background: linear-gradient(transparent, rgba(15,14,11,0.7));
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }
  .caption-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--parchment);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .caption-year {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-style: italic;
    color: var(--gold-mat);
  }

  @media (max-width: 768px) {
    .distinction-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .distinction-right {
      order: -1;
    }
  }
</style>

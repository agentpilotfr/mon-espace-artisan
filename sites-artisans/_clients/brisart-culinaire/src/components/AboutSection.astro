---
// Section À propos — Chef Guillaume Brisard — données réelles
const valeurs = [
  {
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="#C9A44A" stroke-width="1.1" stroke-linecap="round">
      <path d="M14 3 C14 3 6 8 6 15 C6 20 9.5 24 14 24 C18.5 24 22 20 22 15 C22 8 14 3 14 3Z"/>
      <path d="M14 24 L14 12" stroke-dasharray="2 2"/>
      <circle cx="14" cy="11" r="1.5" fill="#C9A44A" stroke="none"/>
    </svg>`,
    titre: 'Produits du marché',
    texte: 'La carte change au fil des arrivages. Légumes de saison, poissons de la côte, éleveurs locaux — Guillaume compose chaque semaine selon ce que la nature propose.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="#C9A44A" stroke-width="1.1" stroke-linecap="round">
      <path d="M14 4 L16 10 L22 10 L17.5 13.5 L19.5 20 L14 16.5 L8.5 20 L10.5 13.5 L6 10 L12 10 Z" stroke-width="0.9"/>
    </svg>`,
    titre: 'Bib Gourmand Michelin',
    texte: 'Distinction obtenue pour une cuisine sincère, précise et généreuse — accessibles aux prix justes. La reconnaissance d\'un travail d\'artisan au quotidien.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="#C9A44A" stroke-width="1.1" stroke-linecap="round">
      <circle cx="10" cy="10" r="6" stroke-width="0.9"/>
      <path d="M10 4 C10 4 6 7 6 10 C6 13 8 15.5 10 16"/>
      <path d="M10 4 C10 4 14 7 14 10 C14 13 12 15.5 10 16"/>
      <line x1="4" y1="10" x2="16" y2="10" stroke-width="0.6"/>
      <line x1="16" y1="18" x2="26" y2="18" stroke-width="1.2"/>
      <line x1="16" y1="22" x2="24" y2="22" stroke-width="1.2"/>
    </svg>`,
    titre: 'Transmission & partage',
    texte: 'Cours de cuisine, ateliers en groupe, immersion journée : Guillaume partage ses techniques depuis 5 ans, de La Baule jusqu\'à Nantes.',
  },
];
---

<section id="a-propos" class="about-section clip-bottom">
  <div class="container">
    <div class="about-grid">

      <!-- Visual côté gauche -->
      <div class="about-visual" data-reveal="left">
        <div class="about-img-frame">
          <div class="img-wrap about-portrait">
            <img
              src="/images/guillaume/portrait-nb-logo.webp"
              alt="Guillaume Brisard chef Bib Gourmand Bris'Art Culinaire La Baule"
              width="600"
              height="750"
              loading="eager"
              style="width:100%; height:100%; object-fit:cover; display:block; border-radius:var(--radius-card);"
            >
          </div>
          <!-- Détail lifestyle premium -->
          <div class="about-detail-img">
            <img
              src="/images/guillaume/detail-montre-audemars.webp"
              alt="Chef Guillaume Brisard — détail signature Bris'Art Culinaire"
              width="600"
              height="400"
              loading="lazy"
              style="width:100%; height:100%; object-fit:cover; display:block; border-radius:8px;"
            >
          </div>

          <!-- Carte Bib Gourmand -->
          <div class="about-exp-card">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true" style="margin:0 auto 0.4rem;">
              <path d="M11 2 L13.2 7.8 L19.5 7.8 L14.6 11.4 L16.8 17.2 L11 13.8 L5.2 17.2 L7.4 11.4 L2.5 7.8 L8.8 7.8 Z" stroke="#C9A44A" stroke-width="0.9" fill="none"/>
            </svg>
            <span class="stat-label" style="color:rgba(245,240,232,0.6); font-size:0.58rem;">Bib Gourmand</span>
            <span style="display:block; font-family:var(--font-display); font-style:italic; color:var(--gold-base); font-size:1rem; margin-top:0.15rem;">Michelin</span>
          </div>
        </div>

        <!-- Decoration botanique -->
        <div class="about-botanical" aria-hidden="true">
          <svg width="120" height="180" viewBox="0 0 120 180" fill="none" style="opacity:0.2;">
            <path d="M60 180 C58 140 62 100 60 60 C58 30 60 10 60 0" stroke="#C9A44A" stroke-width="1.4" stroke-linecap="round"/>
            <path d="M60 140 C48 128 38 120 28 114" stroke="#C9A44A" stroke-width="0.9" stroke-linecap="round" fill="none"/>
            <path d="M60 140 C74 128 84 120 94 115" stroke="#C9A44A" stroke-width="0.9" stroke-linecap="round" fill="none"/>
            <path d="M60 115 C46 102 36 94 24 88" stroke="#C9A44A" stroke-width="0.8" stroke-linecap="round" fill="none"/>
            <path d="M60 115 C76 102 86 95 98 90" stroke="#C9A44A" stroke-width="0.8" stroke-linecap="round" fill="none"/>
            <path d="M60 90 C48 78 40 72 30 67" stroke="#C9A44A" stroke-width="0.75" stroke-linecap="round" fill="none"/>
            <path d="M60 90 C74 78 82 73 92 68" stroke="#C9A44A" stroke-width="0.75" stroke-linecap="round" fill="none"/>
            <path d="M60 66 C50 56 44 50 36 46" stroke="#C9A44A" stroke-width="0.7" stroke-linecap="round" fill="none"/>
            <path d="M60 66 C72 56 78 51 86 47" stroke="#C9A44A" stroke-width="0.7" stroke-linecap="round" fill="none"/>
            <circle cx="60" cy="8" r="4" stroke="#C9A44A" stroke-width="0.8"/>
            <circle cx="56" cy="2" r="2.5" stroke="#C9A44A" stroke-width="0.7"/>
            <circle cx="64" cy="3" r="2.5" stroke="#C9A44A" stroke-width="0.7"/>
          </svg>
        </div>
      </div>

      <!-- Texte côté droit -->
      <div class="about-text" data-reveal="right">
        <span class="section-label">Le Chef</span>
        <div class="gold-rule" style="margin:1rem 0;"></div>

        <h2 style="margin-bottom:0.6rem;">
          Guillaume<br>
          <em style="color:var(--gold-base);">Brisard</em>
        </h2>

        <p class="font-accent" style="font-size:1.3rem; color:var(--stone-light); margin-bottom:1.75rem; line-height:1.5;">
          « Cuisiner, c'est donner à manger une part de soi. »
        </p>

        <p style="color:var(--stone); margin-bottom:1.2rem;">
          Formé dans les plus grandes cuisines françaises, Guillaume Brisard a acquis ses lettres de noblesse
          au <strong style="color:var(--ink);">Fort de l'Océan</strong>, table étoilée au Guide Michelin.
          C'est à La Baule qu'il a choisi de poser ses couteaux et d'ouvrir Bris'Art Culinaire.
        </p>
        <p style="color:var(--stone); margin-bottom:1.2rem;">
          Le restaurant est depuis récompensé du <strong style="color:var(--ink);">Bib Gourmand Michelin</strong>,
          distinction qui vient saluer une cuisine sincère, précise et généreuse — à l'image du chef qui la compose
          chaque jour selon les arrivages du marché.
        </p>
        <p style="color:var(--stone); margin-bottom:1.75rem;">
          Depuis 5 ans, Guillaume partage aussi sa passion lors de cours de cuisine au restaurant ou chez vous,
          de Nantes à La Baule. Peu importe votre niveau : ici, on apprend en faisant, avec le sourire.
        </p>

        <!-- Distinction Michelin -->
        <div class="about-distinction" style="margin-bottom:2.5rem;">
          <img
            src="/images/guillaume/michelin-plaque-2026.webp"
            alt="Plaque Bib Gourmand Guide Michelin 2026 Bris'Art Culinaire"
            width="300"
            loading="lazy"
            style="max-width:160px; border-radius:8px; box-shadow:0 6px 24px rgba(0,0,0,0.15);"
          >
        </div>

        <!-- Valeurs -->
        <div class="about-valeurs">
          {valeurs.map((v) => (
            <div class="valeur-item">
              <div class="valeur-icon" set:html={v.icon} />
              <div>
                <strong class="valeur-titre">{v.titre}</strong>
                <p class="valeur-texte">{v.texte}</p>
              </div>
            </div>
          ))}
        </div>

        <div style="margin-top:2.5rem;">
          <a href="/le-restaurant" class="btn-ghost-gold">Voir le restaurant</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-section {
    background: var(--parchment);
    position: relative;
    overflow: hidden;
    padding: clamp(5rem, 9vw, 9rem) 0;
  }
  .about-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 15% 50%, rgba(201,164,74,0.05) 0%, transparent 60%);
    pointer-events: none;
  }
  .about-grid {
    display: grid;
    gap: 4rem;
    align-items: center;
  }
  @media (min-width: 900px) { .about-grid { grid-template-columns: 1fr 1fr; } }

  .about-img-frame { position: relative; max-width: 360px; margin: 0 auto; }
  .about-portrait { border-radius: var(--radius-card); aspect-ratio: 3/4; max-height: 480px; object-position: top; box-shadow: 0 20px 60px rgba(42,40,36,0.18); }
  .about-portrait-inner { width: 100%; height: 100%; min-height: 340px; display: flex; align-items: center; justify-content: center; }

  .about-detail-img {
    position: absolute;
    top: -1.5rem;
    right: -1.5rem;
    width: 90px;
    height: 90px;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(0,0,0,0.3);
    border: 2px solid rgba(201,164,74,0.3);
  }

  .about-exp-card {
    position: absolute;
    bottom: -1.5rem;
    right: -1.5rem;
    background: var(--ink);
    padding: 1.25rem 1.5rem;
    border-radius: var(--radius-card);
    text-align: center;
    box-shadow: 0 8px 32px rgba(0,0,0,0.25);
  }
  .about-botanical { position: absolute; top: 2rem; left: -3rem; pointer-events: none; }

  .about-text { padding-top: 1rem; }

  .about-valeurs {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--parchment-bg);
  }
  .valeur-item { display: flex; gap: 1.1rem; align-items: flex-start; }
  .valeur-icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(201,164,74,0.1);
    border-radius: 50%;
    margin-top: 0.1rem;
  }
  .valeur-titre { display: block; font-family: var(--font-body); font-size: 0.88rem; font-weight: 600; color: var(--ink); margin-bottom: 0.3rem; }
  .valeur-texte { font-size: 0.875rem; color: var(--stone-light); line-height: 1.65; }
</style>

---
// Carte Bib Gourmand Michelin avec effet tilt 3D au hover
---

<div class="tilt-card" id="michelin-tilt-card" aria-label="Guide Michelin Bib Gourmand 2026">
  <div class="tilt-inner">
    <!-- Shine overlay -->
    <div class="tilt-shine" aria-hidden="true"></div>

    <!-- Michelin Bibendum SVG -->
    <div class="tilt-bib" aria-hidden="true">
      <svg
        viewBox="0 0 80 110"
        xmlns="http://www.w3.org/2000/svg"
        fill="white"
        role="img"
        aria-label="Bibendum Michelin"
        style="width:90px; height:auto;"
      >
        <!-- Corps simplifié du Bibendum -->
        <ellipse cx="40" cy="55" rx="24" ry="22" opacity="0.95"/>
        <ellipse cx="40" cy="35" rx="20" ry="18" opacity="0.95"/>
        <!-- Tête -->
        <circle cx="40" cy="16" r="14" opacity="0.95"/>
        <!-- Yeux -->
        <circle cx="35" cy="13" r="2.5" fill="#CC0000"/>
        <circle cx="45" cy="13" r="2.5" fill="#CC0000"/>
        <!-- Sourire -->
        <path d="M34 19 Q40 24 46 19" fill="none" stroke="#CC0000" stroke-width="1.8" stroke-linecap="round"/>
        <!-- Bras gauche -->
        <ellipse cx="19" cy="44" rx="7" ry="11" transform="rotate(-30 19 44)" opacity="0.9"/>
        <!-- Bras droit -->
        <ellipse cx="61" cy="44" rx="7" ry="11" transform="rotate(30 61 44)" opacity="0.9"/>
        <!-- Jambes -->
        <ellipse cx="31" cy="78" rx="10" ry="8" opacity="0.9"/>
        <ellipse cx="49" cy="78" rx="10" ry="8" opacity="0.9"/>
        <!-- Pieds -->
        <ellipse cx="28" cy="90" rx="10" ry="6" opacity="0.85"/>
        <ellipse cx="52" cy="90" rx="10" ry="6" opacity="0.85"/>
        <!-- Nœud papillon -->
        <path d="M35 28 L40 31 L45 28 L40 32 Z" fill="#CC0000" opacity="0.8"/>
      </svg>
    </div>

    <!-- Texte -->
    <div class="tilt-content">
      <span class="tilt-label">MICHELIN BIB GOURMAND</span>
      <span class="tilt-year">2026</span>
      <div class="tilt-stars" aria-hidden="true">★ ★ ★</div>
      <span class="tilt-caption">La Baule · France</span>
    </div>
  </div>
</div>

<script>
  const card = document.getElementById('michelin-tilt-card');
  if (card) {
    const inner = card.querySelector('.tilt-inner') as HTMLElement | null;
    const shine = card.querySelector('.tilt-shine') as HTMLElement | null;
    const MAX = 15;

    card.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = card.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width;
      const y = (e.clientY - rect.top) / rect.height;

      const rotX = (y - 0.5) * -MAX * 2;
      const rotY = (x - 0.5) * MAX * 2;

      if (inner) {
        inner.style.transform = `perspective(1000px) rotateX(${rotX}deg) rotateY(${rotY}deg) scale(1.04)`;
      }
      if (shine) {
        const angleX = (x * 100).toFixed(0);
        const angleY = (y * 100).toFixed(0);
        shine.style.background = `radial-gradient(circle at ${angleX}% ${angleY}%, rgba(255,255,255,0.15) 0%, transparent 60%)`;
      }
    });

    card.addEventListener('mouseleave', () => {
      if (inner) inner.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg) scale(1)';
      if (shine) shine.style.background = 'none';
    });
  }
</script>

<style>
  .tilt-card {
    width: 280px;
    height: 320px;
    border-radius: 8px;
    cursor: pointer;
    flex-shrink: 0;
  }

  .tilt-inner {
    width: 100%;
    height: 100%;
    border-radius: 8px;
    background: #CC0000;
    box-shadow: 0 20px 60px rgba(204,0,0,0.25), 0 4px 20px rgba(204,0,0,0.15);
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    padding: 2rem 1.5rem 1.75rem;
    transition: transform 0.5s ease, box-shadow 0.3s ease;
  }

  .tilt-card:hover .tilt-inner {
    box-shadow: 0 30px 80px rgba(204,0,0,0.35), 0 8px 32px rgba(204,0,0,0.2);
  }

  /* Texture subtile */
  .tilt-inner::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 30% 20%, rgba(255,255,255,0.08) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 80%, rgba(0,0,0,0.1) 0%, transparent 50%);
    pointer-events: none;
  }

  /* Bande diagonale déco */
  .tilt-inner::after {
    content: '';
    position: absolute;
    top: -20px;
    right: -30px;
    width: 120px;
    height: 200px;
    background: rgba(255,255,255,0.05);
    transform: rotate(25deg);
    pointer-events: none;
  }

  .tilt-shine {
    position: absolute;
    inset: 0;
    border-radius: 8px;
    pointer-events: none;
    z-index: 2;
    transition: background 0.1s ease;
  }

  .tilt-bib {
    position: relative;
    z-index: 3;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    filter: drop-shadow(0 4px 8px rgba(0,0,0,0.2));
  }

  .tilt-content {
    position: relative;
    z-index: 3;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .tilt-label {
    font-family: "DM Mono", monospace;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.85);
    display: block;
  }

  .tilt-year {
    font-family: "Cormorant Garamond", Georgia, serif;
    font-style: italic;
    font-size: 2.5rem;
    color: white;
    line-height: 1;
    display: block;
  }

  .tilt-stars {
    color: rgba(255,255,255,0.7);
    font-size: 0.65rem;
    letter-spacing: 0.4em;
  }

  .tilt-caption {
    font-family: "DM Mono", monospace;
    font-size: 0.58rem;
    letter-spacing: 0.15em;
    color: rgba(255,255,255,0.5);
    text-transform: uppercase;
  }
</style>

<style>
  /* ─── Hero container ─── */
  .hero-parallax {
    position: relative;
    width: 100%;
    height: 100svh;
    min-height: 600px;
    display: flex;
    align-items: stretch;
    overflow: hidden;
    background: var(--ink-deep);
    background-image: url('/images/hero-poster.jpg');
    background-size: cover;
    background-position: center top;
  }

  /* ─── Vidéo background ─── */
  .hero-video {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  /* ─── Overlay ─── */
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(15, 14, 11, 0.25) 0%,
      rgba(15, 14, 11, 0.35) 50%,
      rgba(15, 14, 11, 0.72) 100%
    );
    z-index: 1;
  }

  /* ─── Couches parallax ─── */
  .parallax-layer {
    position: absolute;
    pointer-events: none;
    will-change: transform;
    z-index: 2;
  }

  /* ─── Ornements ─── */
  .hero-ornaments { position: absolute; inset: 0; pointer-events: none; z-index: 3; }
  .orn-line-v {
    position: absolute;
    top: 15%; bottom: 15%; width: 1px;
    background: linear-gradient(to bottom, transparent, rgba(201,164,74,0.22) 30%, rgba(201,164,74,0.22) 70%, transparent);
  }
  .orn-left  { left: clamp(1rem, 4vw, 3.5rem); }
  .orn-right { right: clamp(1rem, 4vw, 3.5rem); }
  .orn-corner { position: absolute; z-index: 3; }
  .orn-corner-bl { bottom: 1.5rem; left: 1.5rem; }
  .orn-corner-br { bottom: 1.5rem; right: 1.5rem; }

  /* ─────────────────────────────────────────── */
  /* CONTENU — FLEX COLUMN MOBILE FIRST          */
  /* ─────────────────────────────────────────── */
  .hero-content {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    width: 100%;
    /* top = navbar height, bottom = safe area */
    padding: 5rem 1.5rem 2rem;
    gap: 0;
    box-sizing: border-box;
  }

  /* ─── Logo mobile ─── */
  .hero-logo-wrap {
    width: 100%;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero-logo-main {
    width: clamp(180px, 55vw, 280px);
    height: auto;

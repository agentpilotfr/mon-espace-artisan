<script>
  (function () {
    /* ─── Parallax scroll ─── */
    const layers = document.querySelectorAll<HTMLElement>('.parallax-layer[data-speed]');
    const hero   = document.getElementById('hero-parallax');
    if (hero && layers.length) {
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!prefersReduced) {
        let scrollY = 0;
        let dirty   = false;
        function apply() {
          const heroH = hero!.offsetHeight;
          if (scrollY > heroH) return;
          layers.forEach(layer => {
            const speed = parseFloat(layer.dataset.speed || '0');
            layer.style.transform = `translateY(${scrollY * speed}px)`;
          });
        }
        window.addEventListener('scroll', () => {
          scrollY = window.scrollY;
          if (!dirty) { dirty = true; requestAnimationFrame(() => { apply(); dirty = false; }); }
        }, { passive: true });
        apply();
      }
    }

    /* ─── Bib parallax tilt ─── */
    const bibCard = document.getElementById('hero-bib-tilt');
    if (!bibCard) return;
    bibCard.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = bibCard.getBoundingClientRect();
      const dx = (e.clientX - rect.left - rect.width / 2) / (rect.width / 2);
      const dy = (e.clientY - rect.top - rect.height / 2) / (rect.height / 2);
      const rotX = -dy * 18;
      const rotY =  dx * 18;
      (bibCard as HTMLElement).style.transition = 'transform 0.05s linear, box-shadow 0.05s linear';
      (bibCard as HTMLElement).style.transform = `perspective(400px) rotateX(${rotX}deg) rotateY(${rotY}deg)`;
      const svgEl = bibCard.querySelector<HTMLElement>('.hero-bib-tilt__svg');
      if (svgEl) {
        svgEl.style.transition = 'transform 0.05s linear';
        svgEl.style.transform = `translateZ(14px) translateX(${(dx*5).toFixed(1)}px) translateY(${(dy*5).toFixed(1)}px)`;
      }
    });
    bibCard.addEventListener('mouseleave', () => {
      (bibCard as HTMLElement).style.transition = 'transform 0.5s ease, box-shadow 0.5s ease';
      (bibCard as HTMLElement).style.transform = 'perspective(400px) rotateX(0deg) rotateY(0deg)';
      const svgEl = bibCard.querySelector<HTMLElement>('.hero-bib-tilt__svg');
      if (svgEl) {
        svgEl.style.transition = 'transform 0.5s ease';
        svgEl.style.transform = 'translateZ(8px)';
      }
    });
  })();
</script>

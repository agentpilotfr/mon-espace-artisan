<style>
  .hero-parallax {
    position: relative;
    min-height: 100svh; /* svh : exclut la barre d'adresse mobile Safari */
    overflow: hidden;
    background: var(--ink-deep);
    display: flex;
    align-items: center;
  }

  /* ─── Vidéo background ─── */
  .hero-video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  /* Fallback poster si la vidéo ne charge pas (tous écrans) */
  .hero-parallax {
    background-image: url('/images/hero-poster.jpg');
    background-size: cover;
    background-position: center top;
  }

  /* ─── Overlay — max 0.35 pour laisser la vidéo respirer ─── */
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(15, 14, 11, 0.25) 0%,
      rgba(15, 14, 11, 0.35) 50%,
      rgba(15, 14, 11, 0.72) 100%
    );
    z-index: 1;
  }

  /* ─── Couches parallax ─── */
  .parallax-layer {
    position: absolute;
    pointer-events: none;
    will-change: transform;
    z-index: 2;
  }

  /* ─── Ornements ─── */
  .hero-ornaments { position: absolute; inset: 0; pointer-events: none; z-index: 3; }
  .orn-line-v {
    position: absolute;
    top: 15%; bottom: 15%; width: 1px;
    background: linear-gradient(to bottom, transparent, rgba(201,164,74,0.22) 30%, rgba(201,164,74,0.22) 70%, transparent);
  }
  .orn-left  { left: clamp(1rem, 4vw, 3.5rem); }
  .orn-right { right: clamp(1rem, 4vw, 3.5rem); }
  .orn-corner { position: absolute; z-index: 3; }
  .orn-corner-bl { bottom: 1.5rem; left: 1.5rem; }
  .orn-corner-br { bottom: 1.5rem; right: 1.5rem; }

  /* ─── Contenu ─── */
  .hero-content {
    position: relative;
    z-index: 10;
    width: 100%;
  }
  .hero-inner {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
    padding: 8rem 0 6rem;
  }

  /* Badge Michelin */
  .hero-michelin-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(201,164,74,0.12);
    border: 1px solid rgba(201,164,74,0.25);
    border-radius: 20px;
    padding: 0.4rem 1rem;
    margin-bottom: 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold-base);
  }

  .hero-label { letter-spacing: 0.28em; display: block; }

  .hero-logo-main {
    width: clamp(280px, 38vw, 460px);
    height: auto;
    max-height: 120px;
    object-fit: contain;
    filter: drop-shadow(0 2px 20px rgba(0,0,0,0.5));
    margin: 0 auto 2rem;
    display: block;
  }

  .hero-title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(3.8rem, 9vw, 7.5rem);
    line-height: 0.88;
    color: var(--parchment);
    letter-spacing: -0.01em;
    margin: 0 0 1.8rem;
  }
  .hero-title-gold { color: var(--gold-base); font-weight: 400; }

  .hero-subtitle {
    font-family: var(--font-body);
    color: rgba(245,240,232,0.65);
    font-size: clamp(0.95rem, 1.8vw, 1.1rem);
    line-height: 1.75;
    max-width: 520px;
    margin: 0 auto 2.5rem;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 3.5rem;
  }

  .scroll-indicator {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }
  .scroll-line { width: 36px; height: 1px; background: rgba(201,164,74,0.3); }
  .scroll-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(201,164,74,0.4);
  }

  .hero-fade {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 200px;
    background: linear-gradient(to bottom, transparent 0%, rgba(28,26,24,0.7) 70%, var(--ink-deep) 100%);
    pointer-events: none;
    z-index: 4;
  }

  /* Styles reviews → voir HeroReviews.astro */
</style>

<script>
  (function () {
    const layers = document.querySelectorAll<HTMLElement>('.parallax-layer[data-speed]');
    const hero   = document.getElementById('hero-parallax');
    if (!hero || !layers.length) return;

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced) return;

    let scrollY = 0;
    let dirty   = false;

    function apply() {
      const heroH = hero!.offsetHeight;
      if (scrollY > heroH) return;
      layers.forEach(layer => {
        const speed = parseFloat(layer.dataset.speed || '0');
        layer.style.transform = `translateY(${scrollY * speed}px)`;
      });
    }

    window.addEventListener('scroll', () => {
      scrollY = window.scrollY;
      if (!dirty) {
        dirty = true;
        requestAnimationFrame(() => { apply(); dirty = false; });
      }
    }, { passive: true });

    apply();
  })();
</script>

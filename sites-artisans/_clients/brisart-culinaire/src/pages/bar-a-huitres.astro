---
import BaseLayout          from '../layouts/BaseLayout.astro';
import Header              from '../components/Header.astro';
import DistinctionSection  from '../components/DistinctionSection.astro';
import StatsBand           from '../components/StatsBand.astro';
import ReservationCTA      from '../components/ReservationCTA.astro';
import Footer              from '../components/Footer.astro';
---

<BaseLayout
  title="Bar à Huîtres — Bris'Art Culinaire La Baule | Chaque Dimanche 11h–16h"
  description="Chaque dimanche de 11h à 16h, Guillaume ouvre son bar à huîtres. Huîtres des claires de Mesquer, ouvertes à la minute. Vins blancs de Loire. Sans réservation. La Baule."
  canonical="https://www.brisartculinaire.fr/bar-a-huitres"
>
  <Header />
  <main>

    <!-- ─── Hero ─── -->
    <section class="bah-hero">
      <img
        src="/images/guillaume/cuisine-mains-huitres-nb.webp"
        alt=""
        aria-hidden="true"
        class="bah-hero-bg-img"
        loading="eager"
        fetchpriority="high"
      />
      <div class="bah-hero-overlay" aria-hidden="true"></div>
      <div class="container bah-hero-content">
        <div class="bah-badge">Dimanche · 11h – 16h</div>
        <div class="gold-rule" style="margin:1rem 0;"></div>
        <h1>Bar à <em class="h1-gold">Huîtres</em></h1>
        <p class="bah-hero-sub">Des claires de Mesquer à votre table, ouverts à la minute.</p>
      </div>
    </section>

    <!-- ─── Section principale ─── -->
    <section class="section" style="background:var(--color-bg);">
      <div class="container">
        <div class="bah-main-grid">
          <div data-reveal="left">
            <span class="section-label">L'iode et le large</span>
            <div class="gold-rule" style="margin:1rem 0;"></div>
            <h2>L'iode et le large,<br><em style="color:var(--gold-base);">chaque dimanche</em></h2>
            <p style="color:var(--color-ink-secondary); margin:1.5rem 0 1.2rem; line-height:1.8; max-width:520px;">
              Chaque dimanche matin, Guillaume sélectionne lui-même les huîtres
              directement des claires de Mesquer. Ouverture à la minute,
              accompagnées de vins blancs de Loire, rillettes de la mer
              et assiettes de coquillages selon l'arrivage.
            </p>
            <p style="color:var(--color-ink-secondary); margin-bottom:1.75rem; line-height:1.8; max-width:520px;">
              Pas de réservation, pas de chichi — la mer à votre table.
            </p>

            <!-- Badges -->
            <div class="bah-badges">
              <span class="bah-tag">Huîtres des claires de Mesquer</span>
              <span class="bah-tag">Ouverture à la minute</span>
              <span class="bah-tag">Vins blancs de Loire</span>
              <span class="bah-tag">Sans réservation</span>
            </div>
          </div>

          <div data-reveal="right">
            <figure class="huitres-main-visual">
              <img
                src="/images/guillaume/cuisine-huitres-nb.webp"
                alt="Huîtres des claires de Mesquer ouvertes à la minute — Bar à Huîtres Bris'Art Culinaire"
                loading="lazy"
                width="600"
                height="450"
              />
            </figure>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── Horaires & Adresse ─── -->
    <section class="section" style="background:var(--color-bg-secondary);">
      <div class="container">
        <div class="bah-info-wrap" data-reveal>
          <div class="bah-info-card">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="#C9A44A" stroke-width="1.2" stroke-linecap="round" aria-hidden="true">
              <circle cx="9" cy="9" r="7.5"/>
              <path d="M9 5 L9 9 L12 11"/>
            </svg>
            <div>
              <span class="bah-info-label">Horaires</span>
              <span class="bah-info-val">Dimanche · 11h – 16h</span>
            </div>
          </div>
          <div class="bah-info-card">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="#C9A44A" stroke-width="1.2" stroke-linecap="round" aria-hidden="true">
              <circle cx="9" cy="7.5" r="3.5"/>
              <path d="M9 14 C9 14 3 9.5 3 7.5 C3 4 5.8 2 9 2 C12.2 2 15 4 15 7.5 C15 9.5 9 14 9 14Z"/>
            </svg>
            <div>
              <span class="bah-info-label">Adresse</span>
              <span class="bah-info-val">39, Avenue Louis Lajarrige — 44500 La Baule-Escoublac</span>
            </div>
          </div>
          <div class="bah-info-card">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="#C9A44A" stroke-width="1.2" stroke-linecap="round" aria-hidden="true">
              <path d="M3 8 C3 5 5.5 4 8 5.5 C9 4.5 11.5 4 13.5 5.5 C15 4.5 17.5 5 18 7.5" stroke="none"/>
              <path d="M4 9 C4 6.5 6 5.5 8 6.5 C9 5.5 11 5.5 12.5 6.5 C14 5.5 16 6 16.5 8 C17.5 9 17.5 11 16 12.5 C14.5 14 12 14 11 13 C10 14 7.5 14 6.5 13 C4.5 13.5 2.5 11.5 4 9Z"/>
              <line x1="10" y1="13" x2="10" y2="16"/>
            </svg>
            <div>
              <span class="bah-info-label">Produit</span>
              <span class="bah-info-val">Claires de Mesquer · Ostréiculteur David Retailleau</span>
            </div>
          </div>
        </div>

        <!-- CTA Google Maps -->
        <div style="text-align:center; margin-top:3rem;" data-reveal>
          <a
            href="https://g.co/kgs/brisartculinaire"
            class="btn-gold"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true" style="display:inline; vertical-align:middle; margin-right:0.4rem;">
              <circle cx="7" cy="6.5" r="3"/>
              <path d="M7 12 C7 12 2 8 2 6.5 C2 3.5 4.5 1.5 7 1.5 C9.5 1.5 12 3.5 12 6.5 C12 8 7 12 7 12Z"/>
              <path d="M14 14 L10 10"/>
            </svg>
            Nous trouver sur Google Maps
          </a>
        </div>
      </div>
    </section>

    <DistinctionSection />
    <StatsBand />
    <ReservationCTA />

  </main>
  <Footer />
</BaseLayout>

<style>
  /* ── Hero ── */
  .bah-hero {
    position: relative;
    min-height: 60vh;
    display: flex;
    align-items: flex-end;
    padding: 9rem 0 5rem;
    overflow: hidden;
  }
  .bah-hero-bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .bah-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(15,14,11,0.85) 0%, rgba(15,14,11,0.5) 60%, rgba(15,14,11,0.3) 100%);
  }
  .bah-hero-content {
    position: relative;
    z-index: 1;
  }
  .bah-hero-content h1 {
    color: white;
    margin: 0.75rem 0 0.5rem;
  }
  .h1-gold { color: var(--gold-base); font-style: italic; }
  .bah-hero-sub {
    color: rgba(245,240,232,0.7);
    font-size: 1.05rem;
    letter-spacing: 0.02em;
  }
  .bah-badge {
    display: inline-flex;
    align-items: center;
    background: rgba(201,164,74,0.12);
    border: 1px solid rgba(201,164,74,0.3);
    border-radius: 20px;
    padding: 0.35rem 0.9rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold-mat);
  }

  /* ── Main grid ── */
  .bah-main-grid {
    display: grid;
    gap: 4rem;
    align-items: center;
  }
  @media (min-width: 900px) { .bah-main-grid { grid-template-columns: 1fr 1fr; } }

  .bah-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 2rem;
  }
  .bah-tag {
    background: rgba(201,164,74,0.08);
    border: 1px solid rgba(201,164,74,0.2);
    border-radius: 20px;
    padding: 0.3rem 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold-mat);
  }

  .huitres-main-visual {
    margin: 0;
    border-radius: var(--radius-card, 8px);
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(26,25,22,0.15);
  }
  .huitres-main-visual img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 4/3;
    object-fit: cover;
  }

  /* ── Info cards ── */
  .bah-info-wrap {
    display: grid;
    gap: 1.5rem;
    max-width: 800px;
    margin: 0 auto;
  }
  @media (min-width: 640px) { .bah-info-wrap { grid-template-columns: repeat(3, 1fr); } }

  .bah-info-card {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding: 1.5rem;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(26,25,22,0.05);
  }
  .bah-info-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold-base);
    margin-bottom: 0.25rem;
  }
  .bah-info-val {
    display: block;
    font-size: 0.875rem;
    color: var(--color-ink-secondary);
    line-height: 1.5;
  }
</style>

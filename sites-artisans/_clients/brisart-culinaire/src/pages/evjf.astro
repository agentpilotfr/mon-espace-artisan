---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header     from '../components/Header.astro';
import Footer     from '../components/Footer.astro';
---

<BaseLayout
  title="EVJF La Baule — Atelier Cuisine Enterrement de Vie de Jeune Fille | Bris'Art Culinaire"
  description="EVJF inoubliable avec Chef Guillaume Brisard entre Nantes et La Baule. Atelier culinaire sur-mesure 3-4h pour 6 à 12 personnes. Accueil bulles, cours ludique, dîner gastronomique."
  canonical="https://www.brisartculinaire.fr/evjf"
>
  <Header transparent={false} />
  <main>

    <!-- Hero -->
    <section class="page-hero">
      <div class="hero-bg-img" style="background-image:url('/images/guillaume/evjf/evjf.webp');" aria-hidden="true"></div>
      <div class="hero-overlay" aria-hidden="true"></div>
      <div class="container hero-content">
        <span class="section-label" style="color:var(--gold-bright);">Pour la future mariée</span>
        <div class="gold-rule" style="margin:1rem 0;"></div>
        <h1 style="color:white;">EVJF<br><em style="color:var(--gold-bright);">Inoubliable</em></h1>
        <p class="hero-sub">Une célébration chic et gourmande, loin des clichés.</p>
      </div>
    </section>

    <!-- Intro -->
    <section class="section" style="background:var(--color-bg);">
      <div class="container">
        <div class="evjf-intro-grid">
          <div data-reveal="left">
            <span class="section-label">Un EVJF pas comme les autres</span>
            <div class="gold-rule" style="margin:1rem 0;"></div>
            <h2>L'élégance du partage<br><em style="color:var(--gold-base);">autour d'un repas</em></h2>
            <p style="color:var(--color-ink-secondary); margin-top:1.5rem; line-height:1.8; max-width:500px;">
              Oubliez les clichés — ici, on célèbre la future mariée avec style et gourmandise.
              Guillaume Brisard, chef Bib Gourmand Michelin, crée pour vous une expérience culinaire
              unique qui mêle apprentissage, rires et bonne table.
            </p>
            <p style="color:var(--color-ink-secondary); margin-top:1rem; line-height:1.8; max-width:500px;">
              À votre domicile, dans un gîte ou chez un partenaire entre Nantes et La Baule,
              Guillaume et son équipe se chargent de tout pour que vous profitiez pleinement
              de ce moment magique.
            </p>
          </div>
          <div data-reveal="right">
            <div class="evjf-visual">
              <div class="img-wrap" style="aspect-ratio:4/3; border-radius:8px;">
                <img
                  src="/images/guillaume/cours-convives-souriant.webp"
                  alt="Groupe EVJF atelier cuisine Bris'Art Culinaire La Baule"
                  width="600"
                  height="450"
                  loading="lazy"
                  style="width:100%;height:100%;object-fit:cover;"
                />
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Programme -->
    <section class="section" style="background:var(--color-bg-secondary);">
      <div class="container">
        <div style="text-align:center; margin-bottom:3.5rem;" data-reveal>
          <span class="section-label">Déroulé</span>
          <div class="gold-rule gold-rule-center" style="margin:1rem auto;"></div>
          <h2>Le programme<br><em style="color:var(--gold-base);">de votre journée</em></h2>
        </div>

        <div class="programme-steps">
          {[
            {
              step: '01',
              titre: 'Accueil pétillant',
              desc: 'Arrivée avec bulles, champagne et bouchées maison signées Guillaume. Le ton est donné — chic et festif.',
            },
            {
              step: '02',
              titre: 'Atelier culinaire',
              desc: 'Tabliers noués, le chef vous guide dans la création de plats gastronomiques. L\'atelier est ludique, participatif et adapté à tous les niveaux.',
            },
            {
              step: '03',
              titre: 'Dégustation & photos',
              desc: 'Vous dégustez ensemble les plats préparés. Des moments photos spontanés, des surprises et des fou-rires garantis.',
            },
            {
              step: '04',
              titre: 'Moment de partage',
              desc: 'En option, prolongez la soirée avec un dîner gastronomique complet préparé par Guillaume — un souvenir inoubliable.',
            },
          ].map((s) => (
            <div class="step-item" data-reveal>
              <div class="step-num">{s.step}</div>
              <div class="step-content">
                <h3 style="font-size:1.15rem; color:var(--color-ink); margin-bottom:0.5rem;">{s.titre}</h3>
                <p style="font-size:0.875rem; color:var(--color-ink-secondary); line-height:1.7;">{s.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Infos pratiques -->
    <section class="section" style="background:var(--color-bg);">
      <div class="container">
        <div class="infos-grid">
          <div data-reveal="left">
            <span class="section-label">Infos pratiques</span>
            <div class="gold-rule" style="margin:1rem 0;"></div>
            <h2>Tout ce que vous<br><em style="color:var(--gold-base);">devez savoir</em></h2>

            <div class="infos-list">
              <div class="info-item">
                <div class="info-icon" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="#C9A44A" stroke-width="1.3" stroke-linecap="round">
                    <circle cx="10" cy="10" r="8"/>
                    <path d="M10 6 L10 10 L13 12"/>
                  </svg>
                </div>
                <div>
                  <strong class="info-label">Durée</strong>
                  <span class="info-val">3 à 4 heures</span>
                </div>
              </div>
              <div class="info-item">
                <div class="info-icon" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="#C9A44A" stroke-width="1.3" stroke-linecap="round">
                    <path d="M10 2 C6 2 3 5 3 8 C3 13 10 18 10 18 C10 18 17 13 17 8 C17 5 14 2 10 2Z"/>
                    <circle cx="10" cy="8" r="2.5"/>
                  </svg>
                </div>
                <div>
                  <strong class="info-label">Lieu</strong>
                  <span class="info-val">Domicile, gîte ou partenaire entre Nantes et La Baule</span>
                </div>
              </div>
              <div class="info-item">
                <div class="info-icon" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="#C9A44A" stroke-width="1.3" stroke-linecap="round">
                    <circle cx="10" cy="8" r="4"/>
                    <path d="M4 17 C4 14 6.7 12 10 12 C13.3 12 16 14 16 17"/>
                  </svg>
                </div>
                <div>
                  <strong class="info-label">Groupe</strong>
                  <span class="info-val">6 à 12 personnes</span>
                </div>
              </div>
              <div class="info-item">
                <div class="info-icon" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="#C9A44A" stroke-width="1.3" stroke-linecap="round">
                    <path d="M3 10 L8 15 L17 5"/>
                  </svg>
                </div>
                <div>
                  <strong class="info-label">Sur-mesure</strong>
                  <span class="info-val">Adapté à vos envies, vos goûts et votre budget</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Témoignages -->
          <div data-reveal="right">
            <span class="section-label">Elles l'ont vécu</span>
            <div class="gold-rule" style="margin:1rem 0;"></div>
            <div class="temoignages-evjf">
              <blockquote class="temo-evjf">
                <p>« Une expérience magique, à la fois chic et fun ! Guillaume a su mettre tout le monde à l'aise. »</p>
                <cite>— Marie, La Baule</cite>
              </blockquote>
              <blockquote class="temo-evjf">
                <p>« On a cuisiné, rigolé, trinqué… et mangé comme dans un resto gastro. »</p>
                <cite>— Anaïs</cite>
              </blockquote>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section style="background:var(--ink-deep); padding:4rem 0; text-align:center;">
      <div class="container">
        <h2 style="color:white; margin-bottom:1rem;">Organisez votre EVJF de rêve</h2>
        <p style="color:rgba(245,240,232,0.55); margin-bottom:2rem; max-width:480px; margin-inline:auto;">
          Dites-nous la date, le lieu et le nombre de participantes — Guillaume vous prépare
          une expérience unique et inoubliable.
        </p>
        <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
          <a href="/#rdv" class="btn-gold">Demander un devis</a>
          <a href="tel:+33285959457" class="btn-ghost-light">02 85 95 94 57</a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style>
  .page-hero {
    position: relative;
    min-height: 55vh;
    display: flex;
    align-items: flex-end;
    padding: 8rem 0 4rem;
    overflow: hidden;
  }
  .hero-bg-img {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transform: scale(1.04);
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(20,18,16,0.85) 0%, rgba(20,18,16,0.45) 60%, rgba(20,18,16,0.2) 100%);
  }
  .hero-content { position: relative; z-index: 1; }
  .hero-sub { color: rgba(245,240,232,0.7); font-size: 1.05rem; margin-top:1rem; max-width:480px; }

  .evjf-intro-grid {
    display: grid;
    gap: 4rem;
    align-items: center;
  }
  @media (min-width: 900px) { .evjf-intro-grid { grid-template-columns: 1fr 1fr; } }

  .programme-steps {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    max-width: 700px;
    margin: 0 auto;
  }
  .step-item {
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: 1.5rem;
    align-items: start;
  }
  .step-num {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 2.5rem;
    color: var(--color-bg-tertiary);
    line-height: 1;
    flex-shrink: 0;
    padding-top: 0.1rem;
  }

  .infos-grid {
    display: grid;
    gap: 4rem;
    align-items: start;
  }
  @media (min-width: 900px) { .infos-grid { grid-template-columns: 1fr 1fr; } }

  .infos-list { display: flex; flex-direction: column; gap: 1.25rem; margin-top: 1.75rem; }
  .info-item { display: flex; align-items: flex-start; gap: 1rem; }
  .info-icon {
    width: 36px;
    height: 36px;
    background: rgba(201,164,74,0.08);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .info-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold-base);
    margin-bottom: 0.15rem;
  }
  .info-val { font-size: 0.875rem; color: var(--color-ink-secondary); line-height: 1.5; }

  .temoignages-evjf { display: flex; flex-direction: column; gap: 1.25rem; margin-top: 1.75rem; }
  .temo-evjf {
    padding: 1.25rem 1.5rem;
    background: var(--color-bg-secondary);
    border-left: 2px solid var(--gold-base);
    border-radius: 0 6px 6px 0;
    margin: 0;
  }
  .temo-evjf p {
    font-family: var(--font-accent);
    font-size: 1.05rem;
    color: var(--color-ink);
    line-height: 1.6;
    margin-bottom: 0.5rem;
  }
  .temo-evjf cite {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    color: var(--color-steel);
    text-transform: uppercase;
    font-style: normal;
  }
</style>

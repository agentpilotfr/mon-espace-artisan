---
import BaseLayout                from '../layouts/BaseLayout.astro';
import Header                   from '../components/Header.astro';
import RestaurantParallaxGallery from '../components/RestaurantParallaxGallery.astro';
import DistinctionSection        from '../components/DistinctionSection.astro';
import StatsBand                 from '../components/StatsBand.astro';
import Testimonials              from '../components/Testimonials.astro';
import ReservationCTA            from '../components/ReservationCTA.astro';
import Footer                   from '../components/Footer.astro';

// Huîtres & produits de la mer — données réelles (scrape 2026-04-26)
const huitres = [
  { produit: '6 huîtres n°3',                               prix: '12 €' },
  { produit: '12 huîtres n°3',                              prix: '19 €' },
  { produit: 'Assiette de crevettes de Madagascar & Aïoli',  prix: '12 €' },
  { produit: 'Assiette de coques au naturel',                prix: '12 €' },
  { produit: 'Pâté à l\'ancienne — Boucherie Le Coz',        prix: '9 €'  },
];

// Menus réels Bris'Art Culinaire (scrape 2026-04-26)
const menus = [
  {
    nom:      'Menu du Marché',
    services: 3,
    prix:     35,
    detail:   'Mercredi — Dimanche · 10h – 16h',
    accroche: 'Menu unique élaboré chaque jour selon les produits du marché et l\'inspiration du chef.',
    plats: [
      'Entrée du marché',
      'Plat selon les arrivages',
      'Dessert maison',
    ],
    img: '/images/guillaume/cuisine-caviar-dressage-pro.webp',
  },
  {
    nom:      'Table du Chef',
    services: 6,
    prix:     125,
    detail:   'Mercredi & Vendredi soir · Sur réservation',
    accroche: 'Une parenthèse intimiste en quelques plats d\'exception — vous êtes les invités privilégiés d\'un moment rare.',
    plats: [
      'Amuse-bouches de saison',
      'Mise en bouche',
      'Entrée du chef',
      'Poisson ou plat intermédiaire',
      'Viande de sélection',
      'Dessert & mignardises',
    ],
    img: '/images/guillaume/action-flambage-pro.webp',
  },
];
---

<BaseLayout
  title="Le Restaurant — Bris'Art Culinaire La Baule | Bib Gourmand Michelin 2026"
  description="Découvrez notre restaurant gastronomique à La Baule. Menu du Marché 35 €, Table du Chef 125 €, Bar à Huîtres. Bib Gourmand Michelin. Réservation en ligne."
  canonical="https://www.brisartculinaire.fr/le-restaurant"
>
  <Header />
  <main>

    <!-- ─── Hero photo ─── -->
    <section class="restaurant-hero">
      <div
        class="hero-bg"
        style="background-image:url('/images/guillaume/restaurant/restaurant.webp');"
        aria-hidden="true"
      ></div>
      <div class="hero-overlay" aria-hidden="true"></div>

      <div class="container hero-content">
        <div class="michelin-badge-hero">
          <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <circle cx="7" cy="7" r="6" stroke="#C9A44A" stroke-width="0.8"/>
            <path d="M5 7 L6.5 8.5 L10 5" stroke="#C9A44A" stroke-width="1.1" stroke-linecap="round"/>
          </svg>
          <span>Bib Gourmand — Guide Michelin 2026</span>
        </div>
        <h1>Le<br><em class="h1-gold">Restaurant</em></h1>
        <p class="hero-sub">Gastronomie &bull; Bar à Huîtres &bull; La Baule-Escoublac</p>
        <div style="margin-top:2rem; display:flex; gap:1rem; flex-wrap:wrap;">
          <a href="https://reservation.laddition.com/booking/brisartculinaire" class="btn-gold" rel="noopener noreferrer" target="_blank">Réserver une table</a>
          <a href="tel:+33285959457" class="btn-ghost-light">02 85 95 94 57</a>
        </div>
      </div>
    </section>

    <!-- ─── Intro & Horaires ─── -->
    <section class="section" style="background:var(--color-bg);">
      <div class="container">
        <div class="intro-grid">
          <div data-reveal="left">
            <span class="section-label">L'Espace</span>
            <div class="gold-rule" style="margin:1rem 0;"></div>
            <h2>Un écrin intimiste<br><em style="color:var(--gold-base);">conçu pour l'échange</em></h2>
            <p style="color:var(--color-ink-secondary); margin:1.5rem 0 1.2rem; line-height:1.8; max-width:480px;">
              Bris'Art Culinaire a été pensé comme un prolongement naturel de la cuisine.
              Vingt couverts seulement, pour que chaque tablée soit unique. La cuisine ouverte,
              visible depuis chaque table, invite au dialogue — Guillaume compose ses plats à vue,
              comme un peintre qui travaille à la lumière.
            </p>
            <p style="color:var(--color-ink-secondary); margin-bottom:1.75rem; line-height:1.8; max-width:480px;">
              Anciennement étoilé au Fort de l'Océan, Guillaume Brisard a choisi La Baule pour
              ouvrir un espace à son image : généreux, précis, et profondément artisanal.
            </p>
            <a href="https://reservation.laddition.com/booking/brisartculinaire" class="btn-ghost-gold" rel="noopener noreferrer" target="_blank">Réserver une table</a>
          </div>

          <div data-reveal="right">
            <!-- Horaires card -->
            <div class="horaires-card">
              <div class="horaires-card-header">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="#C9A44A" stroke-width="1.1" stroke-linecap="round" aria-hidden="true">
                  <circle cx="8" cy="8" r="6.5"/>
                  <path d="M8 4.5 L8 8 L10.5 10"/>
                </svg>
                <span class="section-label">Horaires d'ouverture</span>
              </div>
              <dl class="horaires-dl">
                <div class="h-row h-row--closed">
                  <dt>Lundi & Mardi</dt>
                  <dd>Fermé</dd>
                </div>
                <div class="h-row">
                  <dt>Mercredi — Dimanche</dt>
                  <dd>10h – 16h <small>déjeuner</small></dd>
                </div>
                <div class="h-row h-row--special">
                  <dt>Mercredi & Vendredi soir</dt>
                  <dd>Sur réservation <small>dîner gastronomique</small></dd>
                </div>
              </dl>
              <div class="horaires-card-footer">
                <span>39, Avenue Louis Lajarrige · 44500 La Baule-Escoublac</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── Parallax Gallery ─── -->
    <section class="section gallery-section" style="background:var(--color-bg-secondary); padding-bottom:5rem;">
      <div class="container" style="margin-bottom:3rem;" data-reveal>
        <span class="section-label">Galerie</span>
        <div class="gold-rule" style="margin:1rem 0;"></div>
        <h2>La Salle<br><em style="color:var(--gold-base);">& la Cuisine</em></h2>
      </div>
      <RestaurantParallaxGallery />
    </section>

    <!-- ─── Menus ─── -->
    <section class="section" style="background:var(--color-bg-secondary);" id="menus">
      <div class="container">
        <div style="text-align:center; max-width:560px; margin:0 auto 3.5rem;" data-reveal>
          <span class="section-label">La Carte</span>
          <div class="gold-rule gold-rule-center" style="margin:1rem auto;"></div>
          <h2>Nos <em style="color:var(--gold-base);">menus</em></h2>
          <p style="color:var(--color-ink-secondary); margin-top:1rem; font-size:0.9rem; line-height:1.7;">
            La carte évolue chaque semaine selon les arrivages du marché.
          </p>
        </div>

        <div class="menus-grid">
          {menus.map((menu, i) => (
            <article class="menu-card" data-reveal style={`transition-delay:${i * 0.15}s`}>
              <div class="menu-photo-wrap">
                <img
                  src={menu.img}
                  alt={menu.nom + ' — Bris\'Art Culinaire'}
                  width="560"
                  height="240"
                  loading="lazy"
                  class="menu-photo"
                />
                <div class="menu-photo-overlay" aria-hidden="true"></div>
              </div>

              <div class="menu-body">
                <div class="menu-header">
                  <div>
                    <h3 class="menu-title">{menu.nom}</h3>
                    {menu.services && (
                      <span class="menu-services">{menu.services} services</span>
                    )}
                  </div>
                  <div class="menu-prix-block">
                    <span class="menu-prix">{menu.prix} €</span>
                    <span class="menu-prix-label">/ pers</span>
                  </div>
                </div>

                <p class="menu-accroche">{menu.accroche}</p>

                <ul class="menu-plats">
                  {menu.plats.map(plat => (
                    <li class="menu-plat">
                      <span class="menu-plat-dot" aria-hidden="true">·</span>
                      {plat}
                    </li>
                  ))}
                </ul>

                <div class="menu-detail">
                  <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="#C9A44A" stroke-width="1.1" aria-hidden="true" style="flex-shrink:0;">
                    <circle cx="6" cy="6" r="5"/>
                    <line x1="6" y1="3" x2="6" y2="6.5"/>
                    <line x1="6" y1="6.5" x2="8" y2="8"/>
                  </svg>
                  {menu.detail}
                </div>

                <a href="https://reservation.laddition.com/booking/brisartculinaire" class="menu-cta" rel="noopener noreferrer" target="_blank">
                  Réserver ce menu →
                </a>
              </div>
            </article>
          ))}
        </div>

        <p style="text-align:center; color:var(--color-steel); font-family:var(--font-mono); font-size:0.62rem; letter-spacing:0.1em; margin-top:3rem;" data-reveal>
          Allergènes disponibles sur demande · Accord mets &amp; vins proposé par le chef
        </p>
      </div>
    </section>

    <!-- ─── Bar à Huîtres ─── -->
    <section class="section" style="background:var(--color-bg);" id="bar-a-huitres">
      <div class="container">
        <div class="bah-grid">
          <div data-reveal="left">
            <span class="section-label">Bar à Huîtres</span>
            <div class="gold-rule" style="margin:1rem 0;"></div>
            <h2>Huîtres &amp;<br><em style="color:var(--gold-base);">Produits de la mer</em></h2>
            <p style="color:var(--color-ink-secondary); margin:1.5rem 0 1.2rem; line-height:1.8; max-width:460px;">
              Guillaume s'est associé à <strong style="color:var(--color-ink);">David Retailleau</strong>,
              ostréiculteur à Mesquer, pour proposer des huîtres fraîches directement sorties des claires
              de la Loire-Atlantique.
            </p>
            <p style="color:var(--color-ink-secondary); margin-bottom:1.75rem; line-height:1.8; max-width:460px;">
              À déguster en salle ou en terrasse, accompagnées d'une sélection de produits de la mer
              et de charcuteries locales.
            </p>

            <!-- Photo -->
            <div class="bah-photo-wrap">
              <img
                src="/images/guillaume/cuisine-mains-huitres-nb.webp"
                alt="Huîtres fraîches Bar à Huîtres Bris'Art Culinaire La Baule"
                width="520"
                height="320"
                loading="lazy"
                class="bah-photo"
              />
            </div>
          </div>

          <div data-reveal="right">
            <div class="huitres-carte">
              <div class="huitres-header">
                <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="#C9A44A" stroke-width="1.1" stroke-linecap="round" aria-hidden="true">
                  <path d="M3 8 C3 5 5.5 4 8 5.5 C9 4.5 11.5 4 13.5 5.5 C15 4.5 17.5 5 18 7.5 C20 8.5 20 11 18.5 12.5 C17 14.5 14 14.5 12.5 13 C11 14.5 8 14.5 6.5 13 C4 13.5 2 11.5 3 8Z"/>
                  <line x1="10" y1="13" x2="10" y2="17"/>
                </svg>
                <span class="section-label" style="color:var(--gold-bright);">Carte du Bar à Huîtres</span>
              </div>
              {huitres.map((h) => (
                <div class="huitre-ligne">
                  <span class="huitre-produit">{h.produit}</span>
                  <span class="huitre-prix">{h.prix}</span>
                </div>
              ))}
              <p class="huitres-note">Huîtres de Mesquer · David Retailleau · Service Mer–Dim</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── CTA final ─── -->
    <section style="background:var(--ink-deep); padding:5rem 0; text-align:center;">
      <div class="container">
        <span class="section-label">Réservation</span>
        <div class="gold-rule gold-rule-center" style="margin:1rem auto;"></div>
        <h2 style="color:white; margin-bottom:1rem;">Réservez votre table</h2>
        <p style="color:rgba(245,240,232,0.5); margin-bottom:2.5rem; max-width:460px; margin-inline:auto; line-height:1.75;">
          Disponibilités en temps réel — réservation confirmée instantanément via L'Addition.
        </p>
        <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
          <a href="https://reservation.laddition.com/booking/brisartculinaire" class="btn-gold" rel="noopener noreferrer" target="_blank">
            Réserver en ligne
          </a>
          <a href="tel:+33285959457" class="btn-ghost-light">02 85 95 94 57</a>
        </div>
      </div>
    </section>

    <DistinctionSection />
    <StatsBand />
    <Testimonials />
    <ReservationCTA />
  </main>
  <Footer />
</BaseLayout>

<style>
  /* ── Hero ── */
  .restaurant-hero {
    position: relative;
    height: 80vh;
    min-height: 560px;
    display: flex;
    align-items: flex-end;
    padding: 9rem 0 5rem;
    overflow: hidden;
  }
  @media (max-width: 768px) {
    .restaurant-hero {
      height: 75vh;
      min-height: 480px;
    }
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center top;
    transform: scale(1.03);
  }
  @media (max-width: 768px) {
    .hero-bg {
      background-position: 65% top;
    }
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(26,25,22,0.78) 0%, rgba(26,25,22,0.45) 55%, rgba(26,25,22,0.18) 100%);
  }
  .hero-content {
    position: relative;
    z-index: 1;
  }
  .hero-content h1 {
    color: white;
    margin: 0.75rem 0 0.5rem;
  }
  .h1-gold { color: var(--gold-base); }
  .hero-sub {
    color: rgba(245,240,232,0.65);
    font-size: 1rem;
    letter-spacing: 0.04em;
    margin-top: 0.5rem;
  }

  /* Michelin badge dans le hero */
  .michelin-badge-hero {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    background: rgba(201,164,74,0.12);
    border: 1px solid rgba(201,164,74,0.3);
    border-radius: 20px;
    padding: 0.3rem 0.8rem;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold-mat);
    margin-bottom: 1.5rem;
  }

  /* ── Intro / Horaires ── */
  .intro-grid {
    display: grid;
    gap: 4rem;
    align-items: start;
  }
  @media (min-width: 900px) { .intro-grid { grid-template-columns: 1fr 1fr; } }

  .horaires-card {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 2rem;
    box-shadow: 0 2px 20px rgba(26,25,22,0.06);
  }
  .horaires-card-header {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }
  .horaires-dl {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin: 0;
  }
  .h-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
    align-items: start;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }
  .h-row:last-child { border-bottom: none; padding-bottom: 0; }
  .h-row dt {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    color: var(--color-ink-secondary);
  }
  .h-row dd {
    font-size: 0.88rem;
    color: var(--color-ink);
    margin: 0;
    line-height: 1.4;
  }
  .h-row dd small {
    display: block;
    font-size: 0.65rem;
    color: var(--color-steel);
    margin-top: 0.1rem;
  }
  .h-row--closed dd { color: var(--color-steel); }
  .h-row--special dd { color: var(--gold-base); }
  .horaires-card-footer {
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.06em;
    color: var(--color-steel);
    text-transform: uppercase;
  }

  /* ── Gallery section ── */
  .gallery-section {}

  /* ── Menus ── */
  .menus-grid {
    display: grid;
    gap: 1.5rem;
    max-width: 920px;
    margin: 0 auto;
  }
  @media (min-width: 640px) { .menus-grid { grid-template-columns: repeat(2, 1fr); } }

  .menu-card {
    background: white;
    border: 1px solid rgba(201,164,74,0.2);
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 2px 16px rgba(26,25,22,0.06);
    transition: border-color 0.3s, box-shadow 0.3s;
  }
  .menu-card:hover {
    border-color: rgba(201,164,74,0.4);
    box-shadow: 0 4px 28px rgba(26,25,22,0.1);
  }

  .menu-photo-wrap {
    position: relative;
    height: 200px;
    overflow: hidden;
  }
  .menu-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: brightness(0.75) saturate(0.9);
    transition: transform 0.5s ease, filter 0.4s ease;
  }
  .menu-card:hover .menu-photo {
    transform: scale(1.04);
    filter: brightness(0.85) saturate(1);
  }
  .menu-photo-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 30%, rgba(20,18,16,0.65) 100%);
  }

  .menu-body {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    flex: 1;
  }

  .menu-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }
  .menu-title {
    font-size: 1.2rem;
    color: var(--color-ink);
    margin-bottom: 0.3rem;
  }
  .menu-services {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    color: var(--gold-base);
    text-transform: uppercase;
  }
  .menu-prix-block { text-align: right; flex-shrink: 0; }
  .menu-prix {
    display: block;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.9rem;
    color: var(--gold-base);
    line-height: 1;
  }
  .menu-prix-label {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    color: var(--color-steel);
    letter-spacing: 0.1em;
  }
  .menu-accroche {
    font-style: italic;
    color: var(--color-ink-secondary);
    font-size: 0.86rem;
    line-height: 1.65;
  }
  .menu-plats {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
    border-top: 1px solid var(--color-border);
    padding-top: 0.9rem;
  }
  .menu-plat {
    display: flex;
    gap: 0.55rem;
    font-size: 0.82rem;
    color: var(--color-ink-secondary);
    line-height: 1.5;
  }
  .menu-plat-dot { color: var(--gold-base); flex-shrink: 0; }
  .menu-detail {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    color: var(--color-steel);
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
  }
  .menu-cta {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold-base);
    transition: color 0.2s, letter-spacing 0.2s;
  }
  .menu-cta:hover { color: var(--gold-mat); letter-spacing: 0.16em; }

  /* ── Bar à Huîtres ── */
  .bah-grid {
    display: grid;
    gap: 4rem;
    align-items: center;
  }
  @media (min-width: 900px) { .bah-grid { grid-template-columns: 1fr 1fr; } }

  .bah-photo-wrap {
    margin-top: 2rem;
    border-radius: 8px;
    overflow: hidden;
  }
  .bah-photo {
    width: 100%;
    height: 260px;
    object-fit: cover;
    display: block;
    filter: grayscale(25%);
    transition: filter 0.4s ease;
  }
  .bah-photo:hover { filter: grayscale(0%); }

  .huitres-carte {
    background: var(--ink-deep);
    border: 1px solid rgba(201,164,74,0.18);
    border-radius: 8px;
    padding: 2rem;
  }
  .huitres-header {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    margin-bottom: 1.75rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(201,164,74,0.15);
  }
  .huitre-ligne {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.65rem 0;
    border-bottom: 1px solid rgba(245,240,232,0.06);
    gap: 1rem;
  }
  .huitre-ligne:last-of-type { border-bottom: none; }
  .huitre-produit {
    font-size: 0.87rem;
    color: rgba(245,240,232,0.65);
    line-height: 1.4;
  }
  .huitre-prix {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.05rem;
    color: var(--gold-base);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .huitres-note {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.09em;
    color: rgba(245,240,232,0.2);

---
import BaseLayout      from '../layouts/BaseLayout.astro';
import Header          from '../components/Header.astro';
import HeroParallax    from '../components/HeroParallax.astro';
import ServicesRail    from '../components/ServicesRail.astro';
import DishGallery     from '../components/DishGallery.astro';
import AboutSection    from '../components/AboutSection.astro';
import MichelinTiltCard from '../components/MichelinTiltCard.astro';
import StatsBand       from '../components/StatsBand.astro';
import Testimonials    from '../components/Testimonials.astro';
import ReservationCTA  from '../components/ReservationCTA.astro';
import Footer          from '../components/Footer.astro';
---

<BaseLayout
  title="Bris'Art Culinaire — Restaurant Gastronomique & Cours de Cuisine La Baule | Bib Gourmand Michelin 2026"
  description="Guillaume Brisard, chef Bib Gourmand Michelin 2026, vous accueille à La Baule pour un restaurant gastronomique, des cours de cuisine et des événements sur-mesure."
  canonical="https://www.brisartculinaire.fr/"
>
  <Header transparent />
  <main>
    <HeroParallax />
    <ServicesRail />

    <!-- Galerie plats OGL (FIX 3) -->
    <section class="gallery-section">
      <div class="container">
        <p class="gallery-title" data-reveal>Chaque assiette, une signature</p>
      </div>
      <div class="gallery-canvas-wrapper">
        <DishGallery />
      </div>
    </section>

    <!-- Chef à domicile parallax (FIX 5) -->
    <section class="chef-parallax-section">
      <div class="chef-parallax-overlay"></div>
      <div class="chef-parallax-content" data-reveal>
        <span class="section-label" style="color:rgba(255,255,255,0.6);">Événement privé</span>
        <div class="gold-rule" style="margin:1rem 0;"></div>
        <h2 style="color:#fff; margin-bottom:1rem;">Envie de privatiser<br><em style="color:var(--gold-base);">le chef ?</em></h2>
        <p style="color:rgba(255,255,255,0.75); max-width:480px; margin-bottom:2rem; line-height:1.75;">
          Dîner en villa, anniversaire gastronomique, team building culinaire :
          Guillaume se déplace et crée une expérience unique, rien que pour vous.
        </p>
        <a href="/chef-a-domicile" class="btn-gold">Découvrir l'offre</a>
      </div>
    </section>

    <AboutSection />

    <!-- Section Distinction Michelin -->
    <section class="distinction-section" data-reveal>
      <div class="distinction-inner">
        <div class="distinction-text">
          <span class="section-label">Distinction 2026</span>
          <div class="gold-rule" style="margin:1rem 0;"></div>
          <h2>Reconnu par le <em style="color:var(--gold-base);">Guide Michelin</em></h2>
          <p style="margin-top:1.25rem; max-width:480px; font-size:0.85rem; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">
            Bris'Art Culinaire figure au Guide Michelin 2026, récompensé du Bib Gourmand pour la qualité exceptionnelle de sa cuisine au meilleur rapport qualité-prix.
          </p>
          <div style="margin-top:2rem; display:flex; gap:1rem; flex-wrap:wrap; align-items:center;">
            <a href="/le-restaurant" class="btn-ghost-gold">Découvrir le restaurant</a>
            <a
              href="https://reservation.laddition.com/booking/brisartculinaire"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-gold"
            >Réserver une table</a>
          </div>
        </div>
        <MichelinTiltCard />
      </div>
    </section>

    <StatsBand />
    <Testimonials />
    <ReservationCTA />
  </main>
  <Footer />
</BaseLayout>

<style>
  /* ── Galerie plats ── */
  .gallery-section {
    background: var(--ink-deep, #0f0e0b);
    padding: clamp(3rem, 5vw, 5rem) 0 0;
    overflow: hidden;
  }
  .gallery-title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    color: var(--gold-base);
    text-align: center;
    letter-spacing: 0.04em;
    margin-bottom: 2rem;
  }
  .gallery-canvas-wrapper {
    width: 100%;
  }

  /* ── Chef à domicile parallax ── */
  .chef-parallax-section {
    position: relative;
    min-height: 520px;
    display: flex;
    align-items: center;
    background-image: url('/images/guillaume/cuisine-caviar-dressage-pro.webp');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
  }
  .chef-parallax-overlay {
    position: absolute;
    inset: 0;
    background: rgba(15, 14, 11, 0.45);
  }
  .chef-parallax-content {
    position: relative;
    z-index: 1;
    padding: clamp(3rem, 6vw, 5rem) clamp(1.5rem, 5vw, 4rem);
    max-width: 640px;
  }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header     from '../components/Header.astro';
import Footer     from '../components/Footer.astro';
---

<BaseLayout
  title="Cocktail Dînatoire Traiteur — Chef Guillaume Brisard | La Baule Nantes Vannes"
  description="Service cocktail dînatoire gastronomique à domicile avec Chef Guillaume Brisard. La Baule, Nantes, Vannes, rayon 100 km. Pièces salées et sucrées, produits frais et locaux. Sur devis."
  canonical="https://www.brisartculinaire.fr/cocktail-dinatoire"
>
  <Header transparent={false} />
  <main>

    <!-- Hero -->
    <section class="page-hero">
      <div class="hero-bg-img" style="background-image:url('/images/guillaume/cuisine-canapes-colores.webp');" aria-hidden="true"></div>
      <div class="hero-overlay" aria-hidden="true"></div>
      <div class="container hero-content">
        <span class="section-label" style="color:var(--gold-bright);">Traiteur gastronomique</span>
        <div class="gold-rule" style="margin:1rem 0;"></div>
        <h1 style="color:white;">Cocktail<br><em style="color:var(--gold-bright);">Dînatoire</em></h1>
        <p class="hero-sub">Une expérience raffinée et conviviale pour vos réceptions.</p>
      </div>
    </section>

    <!-- Intro -->
    <section class="section" style="background:var(--color-bg);">
      <div class="container">
        <div class="cocktail-intro-grid">
          <div data-reveal="left">
            <span class="section-label">Service traiteur haut de gamme</span>
            <div class="gold-rule" style="margin:1rem 0;"></div>
            <h2>Tout prévu<br><em style="color:var(--gold-base);">pour que vous profitiez</em></h2>
            <p style="color:var(--color-ink-secondary); margin-top:1.5rem; max-width:500px; line-height:1.8;">
              Offrez à vos invités une expérience culinaire raffinée et conviviale grâce à notre
              service de cocktail dînatoire haut de gamme à domicile. Chef Guillaume Brisard prend
              en charge l'intégralité de la prestation pour que vous soyez entièrement disponible
              pour vos convives.
            </p>
            <p style="color:var(--color-ink-secondary); margin-top:1rem; max-width:500px; line-height:1.8;">
              Chaque cocktail dînatoire est conçu selon vos goûts, vos envies et votre budget,
              avec des produits de saison soigneusement sélectionnés et des dressages créatifs
              qui révèlent le savoir-faire du chef.
            </p>
          </div>
          <div data-reveal="right">
            <div class="img-wrap" style="aspect-ratio:4/3; border-radius:8px;">
              <img
                src="/images/guillaume/cuisine-canapes-voyage.webp"
                alt="Canapés et bouchées gastronomiques cocktail dînatoire Bris'Art Culinaire"
                width="600"
                height="450"
                loading="lazy"
                style="width:100%;height:100%;object-fit:cover;"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Ce qui est inclus -->
    <section class="section" style="background:var(--color-bg-secondary);">
      <div class="container">
        <div style="text-align:center; margin-bottom:3.5rem;" data-reveal>
          <span class="section-label">La prestation</span>
          <div class="gold-rule gold-rule-center" style="margin:1rem auto;"></div>
          <h2>Ce qui est<br><em style="color:var(--gold-base);">inclus dans votre soirée</em></h2>
        </div>
        <div class="inclus-grid">
          {[
            {
              icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="#C9A44A" stroke-width="1.1" stroke-linecap="round"><path d="M6 12 C6 8 9.5 5 14 5 C18.5 5 22 8 22 12 C22 16 18.5 20 14 20 L14 23"/><path d="M10 23 L18 23"/></svg>`,
              titre: 'Pièces salées & sucrées',
              texte: 'Bouchées et pièces cocktail élaborées à partir de produits frais et locaux, cuisinées sur place par l\'équipe du chef.',
            },
            {
              icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="#C9A44A" stroke-width="1.1" stroke-linecap="round"><path d="M7 10 L7 20 Q7 22 9 22 L19 22 Q21 22 21 20 L21 10"/><path d="M5 7 C5 5.5 6 4 7 4 L21 4 C22 4 23 5.5 23 7 L22 10 L6 10 Z"/><path d="M14 4 L14 10"/></svg>`,
              titre: 'Service clé en main',
              texte: 'L\'équipe s\'occupe de tout — mise en place, service et rangement. Vous profitez pleinement de vos invités.',
            },
            {
              icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="#C9A44A" stroke-width="1.1" stroke-linecap="round"><path d="M8 6 L8 22"/><path d="M8 10 C8 10 12 10 14 8 C16 6 20 6 20 6"/><path d="M8 16 C8 16 12 16 14 14 C16 12 20 12 20 12"/></svg>`,
              titre: 'Accord mets & vins',
              texte: 'Option accord mets-vins ou mets-champagnes disponible pour sublimer l\'expérience gustative de vos invités.',
            },
            {
              icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="#C9A44A" stroke-width="1.1" stroke-linecap="round"><path d="M14 4 L16.5 10 L23 10 L18 14 L20 20 L14 16 L8 20 L10 14 L5 10 L11.5 10 Z"/></svg>`,
              titre: 'Dressage créatif',
              texte: 'Les présentations reflètent le niveau d\'exigence d\'un chef Bib Gourmand Michelin — une esthétique soignée qui impressionne.',
            },
          ].map(item => (
            <div class="inclus-card card" data-reveal>
              <div class="inclus-icon" set:html={item.icon} />
              <h3 style="font-size:1.05rem; color:var(--color-ink); margin-bottom:0.6rem;">{item.titre}</h3>
              <p style="font-size:0.85rem; color:var(--color-ink-secondary); line-height:1.7;">{item.texte}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Occasions -->
    <section class="section" style="background:var(--color-bg);">
      <div class="container">
        <div class="occasions-wrap">
          <div data-reveal="left">
            <span class="section-label">Vos occasions</span>
            <div class="gold-rule" style="margin:1rem 0;"></div>
            <h2>Idéal pour toutes<br><em style="color:var(--gold-base);">vos célébrations</em></h2>
            <ul class="occasions-list">
              {[
                'Anniversaire chic',
                'Soirée entre amis ou en famille',
                'Événement professionnel ou lancement de produit',
                'Cocktail de mariage ou de baptême',
                'Réception d\'entreprise',
                'Soirée de prestige',
              ].map(o => <li>{o}</li>)}
            </ul>
          </div>

          <div data-reveal="right">
            <div class="zone-card">
              <span class="section-label" style="color:var(--gold-bright);">Zone d'intervention</span>
              <div class="gold-rule" style="margin:1rem 0; background:rgba(201,164,74,0.3);"></div>
              <div class="zone-map-placeholder" aria-label="Carte zone d'intervention">
                <svg width="180" height="140" viewBox="0 0 180 140" fill="none" aria-hidden="true">
                  <!-- Simplified coastal map Loire-Atlantique -->
                  <circle cx="90" cy="70" r="60" stroke="rgba(201,164,74,0.15)" stroke-width="1" fill="rgba(201,164,74,0.04)"/>
                  <circle cx="90" cy="70" r="40" stroke="rgba(201,164,74,0.2)" stroke-width="1" fill="rgba(201,164,74,0.05)"/>
                  <circle cx="90" cy="70" r="20" stroke="rgba(201,164,74,0.3)" stroke-width="1" fill="rgba(201,164,74,0.08)"/>
                  <circle cx="90" cy="70" r="5" fill="#C9A44A"/>
                  <text x="98" y="74" font-family="monospace" font-size="8" fill="#C9A44A" opacity="0.8">La Baule</text>
                </svg>
              </div>
              <div class="zone-villes">
                <span class="zone-ville">La Baule</span>
                <span class="zone-ville">Nantes</span>
                <span class="zone-ville">Vannes</span>
                <span class="zone-ville">Saint-Nazaire</span>
                <span class="zone-ville">Pornic</span>
                <span class="zone-more">+ rayon 100 km</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Image portfolio -->
    <section style="background:var(--color-bg-secondary); padding:4rem 0;">
      <div class="container">
        <div class="portfolio-grid">
          <div class="img-wrap portfolio-img" style="aspect-ratio:1;">
            <img src="/images/guillaume/cuisine-caviar-dressage-pro.webp" alt="Dressage caviar cocktail dînatoire" width="400" height="400" loading="lazy" style="width:100%;height:100%;object-fit:cover;"/>
          </div>
          <div class="img-wrap portfolio-img" style="aspect-ratio:1;">
            <img src="/images/guillaume/cuisine-canapes-colores.webp" alt="Canapés colorés cocktail gastronomique" width="400" height="400" loading="lazy" style="width:100%;height:100%;object-fit:cover;"/>
          </div>
          <div class="img-wrap portfolio-img" style="aspect-ratio:1;">
            <img src="/images/guillaume/cuisine-deux-chefs-pro.webp" alt="Service traiteur cocktail dînatoire La Baule" width="400" height="400" loading="lazy" style="width:100%;height:100%;object-fit:cover;"/>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section style="background:var(--ink-deep); padding:4rem 0; text-align:center;">
      <div class="container">
        <h2 style="color:white; margin-bottom:1rem;">Votre soirée mérite le meilleur</h2>
        <p style="color:rgba(245,240,232,0.55); margin-bottom:1rem; max-width:480px; margin-inline:auto;">
          Décrivez-nous votre projet — Guillaume vous proposera une formule sur-mesure
          pour une soirée inoubliable.
        </p>
        <!-- TODO: Guillaume confirmera le prix définitif -->
        <p style="color:var(--gold-mat); font-family:var(--font-mono); font-size:0.75rem; letter-spacing:0.1em; margin-bottom:2rem;">
          Tarif sur devis — contactez-nous
        </p>
        <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
          <a href="/#rdv" class="btn-gold">Demander un devis</a>
          <a href="mailto:contact@brisartculinaire.fr" style="color:var(--gold-mat); font-family:var(--font-mono); font-size:0.8rem; display:flex; align-items:center; align-self:center;">contact@brisartculinaire.fr</a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style>
  .page-hero {
    position: relative;
    min-height: 55vh;
    display: flex;
    align-items: flex-end;
    padding: 8rem 0 4rem;
    overflow: hidden;
  }
  .hero-bg-img {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transform: scale(1.04);
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(20,18,16,0.85) 0%, rgba(20,18,16,0.45) 60%, rgba(20,18,16,0.2) 100%);
  }
  .hero-content { position: relative; z-index: 1; }
  .hero-sub { color: rgba(245,240,232,0.7); font-size: 1.05rem; margin-top:1rem; max-width:480px; }

  .cocktail-intro-grid {
    display: grid;
    gap: 4rem;
    align-items: center;
  }
  @media (min-width: 900px) { .cocktail-intro-grid { grid-template-columns: 1fr 1fr; } }

  .inclus-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px) { .inclus-grid { grid-template-columns: repeat(2, 1fr); } }

  .inclus-card { padding: 1.75rem; background: white; }
  .inclus-icon {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(201,164,74,0.08);
    border-radius: 50%;
    margin-bottom: 1.1rem;
  }

  .occasions-wrap {
    display: grid;
    gap: 4rem;
    align-items: start;
  }
  @media (min-width: 900px) { .occasions-wrap { grid-template-columns: 1fr 1fr; } }

  .occasions-list {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .occasions-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: var(--color-ink-secondary);
  }
  .occasions-list li::before {
    content: '';
    width: 16px;
    height: 1px;
    background: var(--gold-base);
    flex-shrink: 0;
  }

  .zone-card {
    background: var(--ink-deep);
    border-radius: 8px;
    padding: 2rem;
    color: white;
  }
  .zone-map-placeholder {
    display: flex;
    justify-content: center;
    margin: 1.5rem 0;
  }
  .zone-villes {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .zone-ville {
    background: rgba(201,164,74,0.1);
    border: 1px solid rgba(201,164,74,0.25);
    border-radius: 20px;
    padding: 0.3rem 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold-mat);
  }
  .zone-more {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 20px;
    padding: 0.3rem 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(245,240,232,0.35);
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    border-radius: 8px;
    overflow: hidden;
  }
  .portfolio-img { border-radius: 0; }
</style>
